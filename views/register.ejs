<%- include('partials/head') %>
    <%- include('partials/header') %>

        <main>
            <section class="auth-page">
                <div class="container">
                    <div class="auth-card">
                        <div class="row g-0">
                            <div class="col-lg-5 auth-panel auth-panel--highlight">
                                <div class="auth-brand" style="background: transparent; padding: 10px 14px; border-radius: 10px; display: flex; justify-content: center; align-items: center; border: none;">
                                    <img src="/assets/img/logo.png" alt="Logo" style="height: 250px; width: auto; max-width: 220px; object-fit: contain; display: block;">
                                </div>
                                <h2 class="auth-title" style="color: #ffffff; text-align: center;">Yeni hesap açın.</h2>
                                <p class="auth-subtitle">Kayıt olarak favorilerinizi saklayabilir, sipariş geçmişinizi
                                    görüntüleyebilir ve özel tekliflerden haberdar olabilirsiniz.</p>
                                <ul class="auth-list">
                                    <li>Özel ürünleri daha hızlı takip edin</li>
                                    <li>Favori listesi oluşturun</li>
                                    <li>İleride kolayca alışverişe dönün</li>
                                </ul>
                            </div>
                            <div class="col-lg-7 auth-panel">
                                <h3 class="auth-title" style="font-size: 24px;">Kayıt Ol</h3>
                                <p class="auth-subtitle">Hesabınızı oluşturmak için bilgilerinizi girin.</p>
                                <% if (error) { %>
                                    <div class="alert alert-danger" style="border-radius: 14px;">
                                        <%= error %>
                                    </div>
                                    <% } %>
                                        <form class="auth-form row g-3" action="/auth/register" method="post"
                                            novalidate="novalidate">
                                            <div class="col-12">
                                                <label for="name" class="form-label" style="font-weight: 600;">Ad
                                                    Soyad</label>
                                                <input type="text" class="form-control" id="name" name="name" value=""
                                                    placeholder="Adınız Soyadınız">
                                            </div>
                                            <div class="col-12">
                                                <label for="email" class="form-label"
                                                    style="font-weight: 600;">E-posta</label>
                                                <input type="email" class="form-control" id="email" name="email"
                                                    value="" placeholder="ornek@email.com">
                                            </div>
                                            <div class="col-12">
                                                <label for="password" class="form-label"
                                                    style="font-weight: 600;">Şifre</label>
                                                <input type="password" class="form-control" id="password"
                                                    name="password" value="" placeholder="Şifreniz">
                                            </div>
                                            <div class="col-12 mt-2">
                                                <button type="submit" class="btn_3 w-100">Kayıt Ol</button>
                                            </div>
                                            <div class="col-12 text-center mt-2">
                                                <a href="/login" class="auth-link">Zaten hesabınız var mı? Giriş
                                                    yapın.</a>
                                            </div>
                                        </form>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <%- include('partials/footer') %>