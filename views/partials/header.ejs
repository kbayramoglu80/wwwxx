<style>
    .custom-header {
        font-family: 'Poppins', 'Inter', 'Roboto', sans-serif;
        background: linear-gradient(135deg, #0f172a 0%, #1f2937 45%, #111827 100%);
        border-bottom: 1px solid rgba(255,255,255,0.10);
        box-shadow: 0 10px 30px rgba(5, 12, 28, 0.22);
        position: fixed;
        top: 0;
        left: 0;
        z-index: 1030;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        width: 100%;
        margin: 0;
        padding: 0;
        animation: headerFadeIn 0.8s ease both;
        transition: transform 0.35s ease, opacity 0.35s ease;
        will-change: transform, opacity;
    }

    .custom-header.header-hidden {
        transform: translateY(-110%);
        opacity: 0;
    }

    @keyframes headerFadeIn {
        from {
            opacity: 0;
            transform: translateY(-18px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .custom-header .container-fluid {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 15px;
    }

    /* Top Row - Logo and Top Icons */
    .header-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 0;
        width: 100%;
    }

    .header-logo {
        flex: 1;
        text-align: left;
        position: relative;
    }

    .header-logo a {
        display: inline-flex;
        align-items: center;
        justify-content: flex-start;
        text-decoration: none;
        background: transparent;
        padding: 0;
        border-radius: 0;
        width: auto;
        max-width: 260px;
        min-height: auto;
    }

    .header-logo img {
        height: 110px;
        width: auto;
        max-width: 210px;
        object-fit: contain;
        display: block;
        filter: drop-shadow(0 4px 8px rgba(0,0,0,0.18));
    }

    /* Top Right Icons */
    .header-top-icons {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-left: auto;
    }

    .header-top-icons a {
        color: #f5f7fb;
        font-size: 16px;
        text-decoration: none;
        transition: color 0.3s ease, transform 0.25s ease;
    }

    .header-top-icons a:hover {
        color: var(--premium-gold);
        transform: translateY(-1px);
    }


    /* Navigation Row */
    .header-middle {
        padding: 0;
        border-top: 1px solid rgba(255,255,255,0.10);
        background: transparent;
        width: 100%;
    }

    .header-nav {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 35px;
        list-style: none;
        margin: 0;
        padding: 12px 0;
    }

    .header-nav li {
        display: flex;
        align-items: center;
    }

    .header-nav a {
        color: #f5f7fb;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.3s ease;
        letter-spacing: 0.5px;
        padding: 6px 0;
        position: relative;
        animation: navLinkFadeIn 0.7s ease both;
    }

    .header-nav li:nth-child(2) a { animation-delay: 0.05s; }
    .header-nav li:nth-child(3) a { animation-delay: 0.1s; }
    .header-nav li:nth-child(4) a { animation-delay: 0.15s; }
    .header-nav li:nth-child(5) a { animation-delay: 0.2s; }
    .header-nav li:nth-child(6) a { animation-delay: 0.25s; }

    @keyframes navLinkFadeIn {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .header-nav a:hover {
        color: var(--premium-gold);
    }

    .header-nav .has-submenu {
        position: relative;
    }

    .header-nav .submenu {
        position: absolute;
        top: 100%;
        left: 0;
        min-width: 220px;
        padding: 8px 0;
        margin: 0;
        list-style: none;
        background: #ffffff;
        border-radius: 10px;
        box-shadow: 0 15px 35px rgba(17, 24, 39, 0.16);
        display: none;
        z-index: 1100;
        transform: translateY(4px);
        transition: transform 0.2s ease;
    }

    .header-nav .has-submenu:hover .submenu,
    .header-nav .has-submenu:focus-within .submenu {
        display: block;
        transform: translateY(0);
    }

    .header-nav .submenu a {
        color: #243b63;
        display: block;
        padding: 8px 14px;
        font-size: 12px;
        font-weight: 500;
        animation: none;
    }

    .header-nav .submenu a:hover {
        background: #f7f3ff;
        color: #7c3aed;
    }

    .header-nav .has-submenu:hover .submenu,
    .header-nav .has-submenu:focus-within .submenu {
        display: block;
    }

    .header-nav a::after {
        content: '';
        position: absolute;
        left: 0;
        bottom: 0;
        width: 100%;
        height: 2px;
        background: linear-gradient(90deg, var(--premium-gold), var(--premium-gold-hover));
        transform: scaleX(0);
        transform-origin: center;
        transition: transform 0.3s ease;
    }

    .header-nav a:hover::after {
        transform: scaleX(1);
    }

    /* Search Bar in Header Middle */
    .header-search {
        display: none;
    }

    /* Icons in middle nav */
    .header-icons {
        display: none;
    }

    .header-bottom {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px 0 10px;
        border-top: 1px solid rgba(255,255,255,0.10);
        background: rgba(255,255,255,0.04);
    }

    .header-promo-nav {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 14px 18px;
    }

    .header-promo-nav a {
        color: #f5f7fb;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.4px;
        text-decoration: none;
        transition: color 0.2s ease;
        white-space: nowrap;
    }

    .header-promo-nav a:hover {
        color: #d9c7ff;
    }

    /* Mobile styles */
    @media (max-width: 991px) {
        .header-top {
            display: none !important;
        }

        .header-middle,
        .header-bottom {
            display: none;
        }

        .mobile_menu {
            position: relative;
            margin-top: 0;
            min-height: 0;
        }

        .mobile_menu .slicknav_menu {
            padding: 0;
            background: transparent;
        }

        .mobile_menu .slicknav_btn {
            display: none !important;
            /* Hide default slicknav button */
        }

        .mobile_menu .slicknav_nav {
            margin-top: 5px !important;
            padding: 8px 0;
            border-radius: 12px;
            background: #fff;
            border: 1px solid #e5e5e5;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            position: absolute;
            width: 100%;
            left: 0;
            z-index: 1000;
        }

        .mobile_menu .slicknav_nav a {
            padding: 12px 18px;
            font-size: 14px;
            font-weight: 500;
            color: #2a4066;
            transition: all 0.2s ease;
        }

        .mobile_menu .slicknav_nav a:hover {
            background-color: #fcf9f2;
            color: #c49b45;
        }

        /* Premium Balanced Mobile Header Top */
        .mobile-header-top {
            display: flex !important;
            align-items: center;
            justify-content: space-between;
            padding: 12px 0;
            background-color: #111b35;
            position: relative;
        }

        .mobile-header-left,
        .mobile-header-right {
            display: flex;
            align-items: center;
            gap: 16px;
            width: 90px;
            /* Constrain width to ensure perfect logo centering */
        }

        .mobile-header-left {
            justify-content: flex-start;
        }

        .mobile-header-right {
            justify-content: flex-end;
        }

        .mobile-menu-btn,
        .mobile-search-btn,
        .mobile-icon-link {
            background: transparent;
            border: none;
            color: #ffffff;
            font-size: 20px;
            cursor: pointer;
            padding: 4px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            position: relative;
            transition: color 0.2s ease;
        }

        .mobile-menu-btn:hover,
        .mobile-search-btn:hover,
        .mobile-icon-link:hover {
            color: #ffffff;
        }

        .mobile-cart-badge {
            position: absolute;
            top: -4px;
            right: -8px;
            background-color: #d9534f;
            color: white;
            border-radius: 50%;
            font-size: 10px;
            padding: 2px 5px;
            font-family: sans-serif;
            font-weight: 600;
            line-height: 1;
        }

        .mobile-header-center {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .mobile-logo-link {
            display: block;
            height: auto;
            width: auto;
            position: relative;
            background: transparent;
        }

        .mobile-logo-link img {
            height: 130px;
            width: auto;
            position: absolute;
            top: -42px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1060;
            object-fit: contain;
            background: transparent;
        }

        /* Collapsible Mobile Search Wrapper */
        .mobile-search-wrapper {
            padding: 12px 15px;
            border-top: 1px solid #f5f5f5;
            border-bottom: 1px solid #f5f5f5;
            background-color: #ffffff;
            margin: 0 -15px;
            /* Bleed to full width inside padded container */
            animation: slideDown 0.3s ease-out forwards;
        }

    }
</style>

<header class="custom-header">
    <div class="container-fluid">
        <!-- Top Row: Centered Logo + Top Right Icons -->
        <div class="header-top d-none d-lg-flex">
            <!-- Centered Logo -->
            <div class="header-logo">
                <a href="/">
                    <img src="/assets/img/logo.png" alt="Logo">
                </a>
            </div>

            <!-- Top Right Icons -->
            <div class="header-top-icons">
                <a href="<%= user ? '/user/profile' : '/auth/login' %>" title="<%= user ? 'Hesabım' : 'Giriş Yap' %>">
                    <i class="fas fa-user"></i>
                </a>
                <a href="/cart" title="Sepetim" style="position: relative;">
                    <i class="fas fa-shopping-bag"></i>
                    <span id="cart-count" style="position: absolute; top: -8px; right: -10px; background: #d9534f; color: white; border-radius: 50%; font-size: 10px; width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                        <%= locals.cartCount || 0 %>
                    </span>
                </a>
            </div>
        </div>

        <!-- Navigation Row: Centered Categories -->
        <div class="header-middle d-none d-lg-block">
            <div class="container-fluid">
                <ul class="header-nav">
                    <li><a href="/">Ana sayfa</a></li>
                    <% if (locals.globalCategories && locals.globalCategories.length > 0) { %>
                        <% globalCategories.forEach(category => { %>
                            <% if (category.children && category.children.length > 0) { %>
                                <li class="has-submenu">
                                    <a href="/shop?category=<%= category.slug %>">
                                        <%= category.name %> <i class="fas fa-angle-down ml-1"></i>
                                    </a>
                                    <ul class="submenu">
                                        <% category.children.forEach(child => { %>
                                            <li><a href="/shop?category=<%= child.slug %>"><%= child.name %></a></li>
                                        <% }); %>
                                    </ul>
                                </li>
                            <% } else { %>
                                <li><a href="/shop?category=<%= category.slug %>">
                                    <%= category.name %>
                                </a></li>
                            <% } %>
                        <% }); %>
                    <% } else { %>
                        <li><a href="/shop">Mağaza</a></li>
                    <% } %>
                    <li><a href="/yuzuk-olcusu-bulma">Yüzük Ölçüsü</a></li>
                    <% if (user && user.role === 'admin') { %>
                        <li><a href="/admin" style="color: #d9534f; font-weight: bold;">Admin</a></li>
                    <% } %>
                </ul>
            </div>
        </div>

        <%
            const promoSetting = locals.globalSetting || {};
            const promoLinks = [];
            for (let i = 1; i <= 5; i++) {
                const label = promoSetting['promoNav' + i + 'Label'];
                const category = promoSetting['promoNav' + i + 'Category'];
                if (label && label.trim()) {
                    promoLinks.push({
                        label: label.trim(),
                        href: category && category.trim() ? '/shop?category=' + encodeURIComponent(category.trim()) : '/shop'
                    });
                }
            }
        %>

        <% if (promoLinks.length > 0) { %>
            <div class="header-bottom">
                <div class="container-fluid">
                    <div class="header-promo-nav">
                        <% promoLinks.forEach(link => { %>
                            <a href="<%= link.href %>"><%= link.label %></a>
                        <% }); %>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- Mobile Header -->
        <div class="mobile-header-top d-flex d-lg-none" style="padding: 12px 0; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.10);">
            <!-- Left: Menu Button -->
            <div>
                <button type="button" class="mobile-menu-btn" id="mobileMenuBtn" style="background: none; border: none; font-size: 20px; color: #2a2a2a; cursor: pointer;" aria-label="Menü">
                    <i class="fas fa-bars"></i>
                </button>
            </div>

            <!-- Center: Logo -->
            <div class="mobile-header-center">
                <a href="/" style="display: inline-flex; align-items: center; text-decoration: none;">
                    <img src="/assets/img/logo.png" alt="Logo" style="height: 115px; width: auto; max-width: 150px; object-fit: contain;">
                </a>
            </div>

            <!-- Right: Search + Cart -->
            <div style="display: flex; gap: 12px; align-items: center;">
                <button type="button" class="mobile-search-btn" id="mobileSearchBtn" style="background: none; border: none; font-size: 18px; color: #2a2a2a; cursor: pointer;" aria-label="Arama">
                    <i class="fas fa-search"></i>
                </button>
                <a href="/cart" style="position: relative; text-decoration: none; color: #2a2a2a; font-size: 18px;">
                    <i class="fas fa-shopping-bag"></i>
                    <span id="mobileCartCount" style="position: absolute; top: -8px; right: -8px; background: #d9534f; color: white; border-radius: 50%; font-size: 10px; width: 16px; height: 16px; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                        <%= locals.cartCount || 0 %>
                    </span>
                </a>
            </div>
        </div>

        <!-- Mobile Search Wrapper -->
        <div class="mobile-search-wrapper d-lg-none" id="mobileSearchWrapper" style="display: none; padding: 12px 0; border-bottom: 1px solid #f0f0f0;">
            <form action="/shop" method="GET" style="display: flex; gap: 8px;">
                <input type="text" name="q" placeholder="Ara..." style="flex: 1; padding: 8px 12px; border: 1px solid #e0e0e0; border-radius: 4px; font-size: 13px;">
                <button type="submit" style="background: none; border: none; color: #2a2a2a; cursor: pointer; font-size: 16px;">
                    <i class="fas fa-search"></i>
                </button>
            </form>
        </div>

        <!-- Mobile Menu Placeholder -->
        <div class="mobile_menu d-block d-lg-none"></div>
    </div>
</header>

<!-- Hidden nav for Slicknav to build mobile menu -->
<div class="d-none">
    <ul id="navigation">
        <li><a href="/">Ana Sayfa</a></li>
        <li><a href="/shop">Mağaza</a></li>
        <% if (locals.globalCategories && locals.globalCategories.length> 0) { %>
            <% globalCategories.forEach(category=> { %>
                <% if (category.children && category.children.length > 0) { %>
                    <li>
                        <a href="/shop?category=<%= category.slug %>"><%= category.name %></a>
                        <ul>
                            <% category.children.forEach(child=> { %>
                                <li><a href="/shop?category=<%= child.slug %>"><%= child.name %></a></li>
                            <% }); %>
                        </ul>
                    </li>
                <% } else { %>
                    <li><a href="/shop?category=<%= category.slug %>">
                            <%= category.name %>
                        </a></li>
                <% } %>
            <% }); %>
        <% } %>
        <li><a href="/yuzuk-olcusu-bulma">Yüzük Ölçüsü Hesaplama</a></li>
                        <li><a href="/about">Hakkımızda</a></li>
                        <li><a href="/contact">İletişim</a></li>
                        <li><a href="<%= user ? '/user/profile' : '/auth/login' %>">
                                <%= user ? 'Hesabım' : 'Giriş Yap / Kayıt Ol' %>
                            </a></li>
                        <% if (user && user.role==='admin' ) { %>
                            <li><a href="/admin">Admin Paneli</a></li>
                            <% } %>
    </ul>
</div>

<!-- Mobile Interaction Logic -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // 1. Mobile Search Box Toggle Logic
        const searchBtn = document.getElementById('mobileSearchBtn');
        const searchWrapper = document.getElementById('mobileSearchWrapper');
        const hasJQuery = typeof $ === 'function';

        if (searchBtn && searchWrapper) {
            searchBtn.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();

                try {
                    if (hasJQuery) {
                        const nav = $('ul#navigation');
                        if (nav.length && typeof nav.slicknav === 'function' && nav.slicknav('isOpen')) {
                            nav.slicknav('close');
                            const menuIcon = document.querySelector('#mobileMenuBtn i');
                            if (menuIcon) menuIcon.className = 'fas fa-bars';
                        }
                    }
                } catch (err) {
                    // ignore plugin errors for mobile search toggle
                }

                const isHidden = window.getComputedStyle(searchWrapper).display === 'none';
                if (isHidden) {
                    searchWrapper.style.display = 'block';
                    searchBtn.innerHTML = '<i class="fas fa-times"></i>';
                    searchBtn.style.color = '#d9534f';
                    const input = searchWrapper.querySelector('input');
                    if (input) input.focus();
                } else {
                    searchWrapper.style.display = 'none';
                    searchBtn.innerHTML = '<i class="fas fa-search"></i>';
                    searchBtn.style.color = '';
                }
            });
        }

        // 2. Custom Mobile Menu (Slicknav Wrapper) Toggle Logic
        const menuBtn = document.getElementById('mobileMenuBtn');
        if (menuBtn) {
            menuBtn.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();

                if (searchWrapper && window.getComputedStyle(searchWrapper).display !== 'none') {
                    searchWrapper.style.display = 'none';
                    if (searchBtn) {
                        searchBtn.innerHTML = '<i class="fas fa-search"></i>';
                        searchBtn.style.color = '';
                    }
                }

                if (hasJQuery) {
                    try {
                        const nav = $('ul#navigation');
                        if (nav.length && typeof nav.slicknav === 'function') {
                            nav.slicknav('toggle');
                        }
                    } catch (err) {
                        // ignore if slicknav not loaded
                    }
                }

                const icon = menuBtn.querySelector('i');
                if (icon) {
                    if (icon.classList.contains('fa-bars')) {
                        icon.className = 'fas fa-times';
                    } else {
                        icon.className = 'fas fa-bars';
                    }
                }
            });
        }

        // Hide header on scroll down, show on scroll up
        const headerElement = document.querySelector('.custom-header');
        let lastScrollY = window.pageYOffset || document.documentElement.scrollTop || document.body.scrollTop || 0;
        const hideAfter = 40;

        function closeMobileInteractions() {
            if (searchWrapper && window.getComputedStyle(searchWrapper).display !== 'none') {
                searchWrapper.style.display = 'none';
                if (searchBtn) {
                    searchBtn.innerHTML = '<i class="fas fa-search"></i>';
                    searchBtn.style.color = '';
                }
            }

            if (hasJQuery) {
                try {
                    const nav = $('ul#navigation');
                    if (nav.length && typeof nav.slicknav === 'function') {
                        nav.slicknav('close');
                    }
                } catch (err) {
                    // ignore plugin errors for mobile menu close
                }
            }

            const menuIcon = document.querySelector('#mobileMenuBtn i');
            if (menuIcon && !menuIcon.classList.contains('fa-bars')) {
                menuIcon.className = 'fas fa-bars';
            }
        }

        window.addEventListener('scroll', function () {
            if (!headerElement) return;
            const currentScrollY = window.pageYOffset || document.documentElement.scrollTop || document.body.scrollTop || 0;

            if (currentScrollY > lastScrollY && currentScrollY > hideAfter) {
                headerElement.classList.add('header-hidden');
                closeMobileInteractions();
            } else if (currentScrollY < lastScrollY) {
                headerElement.classList.remove('header-hidden');
            }

            lastScrollY = currentScrollY;
        });

        // Close dropdowns if user clicks outside of header elements
        document.addEventListener('click', function (event) {
            const header = document.querySelector('.custom-header');
            if (header && !header.contains(event.target)) {
                if (searchWrapper && searchWrapper.style.display !== 'none') {
                    $(searchWrapper).slideUp(180);
                    if (searchBtn) {
                        searchBtn.innerHTML = '<i class="fas fa-search"></i>';
                        searchBtn.style.color = '';
                    }
                }
            }
        });
    });
</script>