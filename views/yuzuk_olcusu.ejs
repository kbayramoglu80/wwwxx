                                <script>
                                    // Jewelery Ring Size Chart Data ( Turkish standard sizing table)
                                    const ringSizeChart = [
                                        { size: 7, diameter: 14.96 },
                                        { size: 8, diameter: 15.28 },
                                        { size: 9, diameter: 15.61 },
                                        { size: 10, diameter: 15.92 },
                                        { size: 11, diameter: 16.24 },
                                        { size: 12, diameter: 16.56 },
                                        { size: 13, diameter: 16.88 },
                                        { size: 14, diameter: 17.20 },
                                        { size: 15, diameter: 17.52 },
                                        { size: 16, diameter: 17.83 },
                                        { size: 17, diameter: 18.15 },
                                        { size: 18, diameter: 18.47 },
                                        { size: 19, diameter: 18.79 },
                                        { size: 20, diameter: 19.11 },
                                        { size: 21, diameter: 19.43 },
                                        { size: 22, diameter: 19.75 },
                                        { size: 23, diameter: 20.06 },
                                        { size: 24, diameter: 20.38 },
                                        { size: 25, diameter: 20.70 },
                                        { size: 26, diameter: 21.02 },
                                        { size: 27, diameter: 21.34 },
                                        { size: 28, diameter: 21.66 },
                                        { size: 29, diameter: 21.97 },
                                        { size: 30, diameter: 22.29 }
                                    ];

                                    // Physical constant: A standard 1 TL coin is exactly 26.15 mm in diameter
                                    const oneTLCoinDiameterMm = 26.15;

                                    // State Variables
                                    let currentStep = 1;
                                    let pxPerMm = 9.1778; // Fallback default scale factor (pixels per mm)
                                    let calibrationCirclePixels = 240;

                                    // Initialize components when DOM loaded
                                    document.addEventListener('DOMContentLoaded', function () {
                                        // Populate select element for Step 3 comparator mode
                                        const selectEl = document.getElementById('size-comparator-select');
                                        if (selectEl) {
                                            ringSizeChart.forEach(item => {
                                                const option = document.createElement('option');
                                                option.value = item.size;
                                                option.text = `Ölçü ${item.size} (${item.diameter.toFixed(2)} mm)`;
                                                if (item.size === 15) {
                                                    option.selected = true;
                                                }
                                                selectEl.appendChild(option);
                                            });

                                            // Force jQuery niceSelect to rebuild with the new options
                                            if (typeof $(selectEl).niceSelect === 'function') {
                                                $(selectEl).niceSelect('update');
                                            }
                                        }
                                    });

                                    function goToStep(step) {
                                        // Hide all step content
                                        document.querySelectorAll('.step-content').forEach(el => el.style.display = 'none');

                                        // Show target content
                                        document.getElementById(`step-content-${step}`).style.display = 'block';

                                        // Update step dots
                                        document.querySelectorAll('.step-item').forEach((el, index) => {
                                            const dotNum = index + 1;
                                            const stepNumCircle = el.querySelector('.step-num');

                                            if (dotNum < step) {
                                                // Completed step
                                                el.className = 'step-item active';
                                                el.style.color = '#c5a059';
                                                if (stepNumCircle) {
                                                    stepNumCircle.style.background = '#28a745';
                                                    stepNumCircle.style.color = '#fff';
                                                    stepNumCircle.innerHTML = '<i class="fas fa-check"></i>';
                                                    stepNumCircle.style.boxShadow = '0 4px 10px rgba(40, 167, 69, 0.2)';
                                                }
                                            } else if (dotNum === step) {
                                                // Active step
                                                el.className = 'step-item active';
                                                el.style.color = '#c5a059';
                                                if (stepNumCircle) {
                                                    stepNumCircle.style.background = '#c5a059';
                                                    stepNumCircle.style.color = '#fff';
                                                    stepNumCircle.innerHTML = dotNum;
                                                    stepNumCircle.style.boxShadow = '0 4px 10px rgba(197, 160, 89, 0.3)';
                                                }
                                            } else {
                                                // Inactive step
                                                el.className = 'step-item';
                                                el.style.color = '#aaa';
                                                if (stepNumCircle) {
                                                    stepNumCircle.style.background = '#eee';
                                                    stepNumCircle.style.color = '#888';
                                                    stepNumCircle.innerHTML = dotNum;
                                                    stepNumCircle.style.boxShadow = 'none';
                                                }
                                            }
                                        });

                                        currentStep = step;

                                        // Load default values when entering Step 3
                                        if (step === 3) {
                                            // Compute default values inside Step 3 mode A
                                            calculateRingSize(document.getElementById('ring-measure-slider').value);
                                            // Compute default values inside Step 3 mode B
                                            updateComparatorSize(document.getElementById('size-comparator-select').value);
                                        }
                                    }

                                    // ----------------------------------------------------
                                    // STEP 2: Calibration Functions
                                    // ----------------------------------------------------
                                    function resizeCalibrationCircle(px) {
                                        calibrationCirclePixels = parseInt(px);
                                        const circle = document.getElementById('calibration-circle');
                                        circle.style.width = px + 'px';
                                        circle.style.height = px + 'px';
                                        document.getElementById('cal-pixels-label').innerText = `Genişlik: ${px}px`;
                                    }

                                    function tuneCalibration(change) {
                                        const slider = document.getElementById('calibration-slider');
                                        let newVal = parseInt(slider.value) + change;
                                        if (newVal >= parseInt(slider.min) && newVal <= parseInt(slider.max)) {
                                            slider.value = newVal;
                                            resizeCalibrationCircle(newVal);
                                        }
                                    }

                                    function saveCalibrationAndContinue() {
                                        // Compute scale ratio (pixels per mm)
                                        // Formula: pxPerMm = (Circle Diameter in pixels) / (Physical 1 TL coin Diameter in mm)
                                        pxPerMm = calibrationCirclePixels / oneTLCoinDiameterMm;
                                        console.log(`Calibrated! Scale: ${pxPerMm.toFixed(4)} pixels per millimeter.`);

                                        // Go to final step
                                        goToStep(3);
                                    }

                                    // ----------------------------------------------------
                                    // STEP 3: Measurement Functions
                                    // ----------------------------------------------------
                                    function switchMeasureMode(mode) {
                                        document.querySelectorAll('.measure-tab-btn').forEach(btn => {
                                            btn.classList.remove('active');
                                            btn.style.background = '#fff';
                                            btn.style.color = '#555';
                                            btn.style.borderColor = '#ccc';
                                        });

                                        const activeBtn = document.getElementById(`tab-btn-${mode}`);
                                        if (activeBtn) {
                                            activeBtn.classList.add('active');
                                            activeBtn.style.background = '#c5a059';
                                            activeBtn.style.color = '#fff';
                                            activeBtn.style.borderColor = '#c5a059';
                                        }

                                        document.getElementById('mode-content-ring').style.display = (mode === 'ring' ? 'block' : 'none');
                                        document.getElementById('mode-content-circles').style.display = (mode === 'circles' ? 'block' : 'none');
                                    }

                                    // --- Mode A: Ring Slider resizing & matching ---
                                    function resizeRingMeasureCircle(px) {
                                        const circle = document.getElementById('ring-measure-circle');
                                        circle.style.width = px + 'px';
                                        circle.style.height = px + 'px';

                                        calculateRingSize(px);
                                    }

                                    function tuneRingMeasure(change) {
                                        const slider = document.getElementById('ring-measure-slider');
                                        let newVal = parseInt(slider.value) + change;
                                        if (newVal >= parseInt(slider.min) && newVal <= parseInt(slider.max)) {
                                            slider.value = newVal;
                                            resizeRingMeasureCircle(newVal);
                                        }
                                    }

                                    function calculateRingSize(px) {
                                        // 1. Calculate physical diameter in mm
                                        const physicalDiameterMm = px / pxPerMm;
                                        document.getElementById('ring-diameter-result-label').innerText = physicalDiameterMm.toFixed(2) + ' mm';

                                        // 2. Find the closest match in Turkish ring size chart
                                        let closestMatch = ringSizeChart[0];
                                        let minDifference = Math.abs(physicalDiameterMm - closestMatch.diameter);

                                        for (let i = 1; i < ringSizeChart.length; i++) {
                                            let diff = Math.abs(physicalDiameterMm - ringSizeChart[i].diameter);
                                            if (diff < minDifference) {
                                                minDifference = diff;
                                                closestMatch = ringSizeChart[i];
                                            }
                                        }

                                        // Update Result Text Label
                                        document.getElementById('ring-size-result-label').innerText = closestMatch.size;
                                    }

                                    // --- Mode B: Choose Size & Display ---
                                    function updateComparatorSize(size) {
                                        const sizeNum = parseInt(size);
                                        const item = ringSizeChart.find(o => o.size === sizeNum);
                                        if (!item) return;

                                        // Calculate required width in pixels using calibrated scale
                                        const pxWidth = item.diameter * pxPerMm;

                                        // Resize comparison circle
                                        const circle = document.getElementById('ring-compare-circle');
                                        circle.style.width = pxWidth + 'px';
                                        circle.style.height = pxWidth + 'px';

                                        // Update labels
                                        document.getElementById('ring-compare-label').innerText = item.size;
                                        document.getElementById('ring-compare-diameter-label').innerText = item.diameter.toFixed(2) + ' mm';
                                    }
                                </script>

