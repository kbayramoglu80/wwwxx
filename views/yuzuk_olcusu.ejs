<%- include('partials/head') %>
    <% if (typeof embed==='undefined' || !embed) { %>
        <%- include('partials/header') %>
            <% } %>

                <main class="page-ring-body">
                    <style>
                        .page-ring-body {
                            background: radial-gradient(circle at top, rgba(197,160,89,0.15) 0%, rgba(12,21,45,0.95) 55%, #071126 100%);
                            color: #f5f1e8;
                        }

                        .page-ring-body .slider-area {
                            background: transparent;
                            padding: 40px 0 0;
                        }

                        .page-ring-body .hero-cap h2 {
                            font-family: 'Cinzel', serif;
                            color: #f8f6ec;
                            font-size: 52px;
                            font-weight: 700;
                            text-transform: uppercase;
                            letter-spacing: 0.2em;
                            margin-bottom: 0;
                        }

                        .page-ring-body .ring-size-section {
                            background: rgba(255,255,255,0.98);
                            border: 1px solid rgba(197,160,89,0.18);
                            box-shadow: 0 28px 80px rgba(0, 0, 0, 0.12);
                            border-radius: 32px;
                        }

                        .page-ring-body .section-tittle .brand-label {
                            font-size: 16px;
                            font-weight: 700;
                            letter-spacing: 0.25em;
                            color: #c5a059;
                            text-transform: uppercase;
                            margin-bottom: 14px;
                        }

                        .page-ring-body .section-tittle h2 {
                            color: #111827;
                            font-size: 44px;
                            font-weight: 800;
                            letter-spacing: -0.02em;
                        }

                        .page-ring-body .section-tittle p {
                            color: #4b5261;
                            font-size: 15px;
                        }

                        .page-ring-body .yuzuk-olcer-card {
                            background: #ffffff;
                            border-radius: 30px;
                            box-shadow: 0 22px 60px rgba(8, 27, 55, 0.12);
                            border: 1px solid rgba(197,160,89,0.18);
                            padding: 40px 36px;
                            min-height: 620px;
                        }

                        .page-ring-body .wizard-steps {
                            display: flex;
                            justify-content: space-between;
                            margin-bottom: 34px;
                        }

                        .page-ring-body .step-item {
                            flex: 1;
                            text-align: center;
                            font-size: 13px;
                            font-weight: 700;
                            color: #9a9da9;
                        }

                        .page-ring-body .step-item.active {
                            color: #0f1c35;
                        }

                        .page-ring-body .step-item .step-num {
                            width: 38px;
                            height: 38px;
                            border-radius: 50%;
                            display: inline-flex;
                            align-items: center;
                            justify-content: center;
                            margin: 0 auto 10px;
                            background: #f3f1e9;
                            color: #6b6c72;
                            font-weight: 700;
                            box-shadow: 0 8px 20px rgba(0,0,0,0.06);
                        }

                        .page-ring-body .step-item.active .step-num {
                            background: #c5a059;
                            color: #111827;
                        }

                        .page-ring-body .icon-large {
                            color: #c5a059;
                        }

                        .page-ring-body .step-content h3,
                        .page-ring-body .step-content p {
                            color: #111827;
                        }

                        .page-ring-body .step-content h3 {
                            font-family: 'Montserrat', sans-serif;
                            font-size: 22px;
                            margin-bottom: 16px;
                        }

                        .page-ring-body .step-content p {
                            color: #5e6678;
                        }

                        .page-ring-body .info-box {
                            background: #fdf6eb;
                            border: 1px solid rgba(197,160,89,0.25);
                            border-radius: 16px;
                            padding: 18px 18px 18px 18px;
                            color: #4f5461;
                            line-height: 1.7;
                            box-shadow: 0 12px 28px rgba(0,0,0,0.06);
                        }

                        .page-ring-body .primary-highlight {
                            color: #0f1c35;
                            font-weight: 700;
                        }

                        .page-ring-body .btn-premium-primary,
                        .page-ring-body .btn-premium-secondary,
                        .page-ring-body .btn-tune,
                        .page-ring-body .measure-tab-btn {
                            transition: all 0.2s ease;
                        }

                        .page-ring-body .btn-premium-primary {
                            background: #0f1c35;
                            color: #fff;
                            border: 1px solid #c5a059;
                            padding: 12px 26px;
                            border-radius: 28px;
                        }

                        .page-ring-body .btn-premium-primary:hover {
                            background: #c5a059;
                            color: #0f1c35;
                        }

                        .page-ring-body .btn-premium-secondary {
                            background: transparent;
                            color: #0f1c35;
                            border: 1px solid rgba(197,160,89,0.8);
                            padding: 12px 26px;
                            border-radius: 28px;
                        }

                        .page-ring-body .btn-premium-secondary:hover {
                            background: rgba(197,160,89,0.10);
                        }

                        .page-ring-body .btn-tune {
                            width: 36px;
                            height: 36px;
                            border-radius: 50%;
                            background: #fff;
                            border: 1px solid rgba(13,25,50,0.12);
                            color: #0f1c35;
                            box-shadow: 0 6px 16px rgba(15,28,53,0.08);
                        }

                        .page-ring-body .btn-tune:hover {
                            transform: scale(1.05);
                        }

                        .page-ring-body .measure-tab-btn {
                            padding: 10px 20px;
                            font-size: 13px;
                            border-radius: 28px;
                            border: 1px solid rgba(197,160,89,0.6);
                            background: #fff;
                            color: #0f1c35;
                            min-width: 160px;
                        }

                        .page-ring-body .measure-tab-btn.active {
                            background: #c5a059;
                            color: #0f1c35;
                            border-color: #c5a059;
                        }

                        .page-ring-body #calibration-circle,
                        .page-ring-body #ring-measure-circle,
                        .page-ring-body #ring-compare-circle {
                            box-shadow: 0 18px 46px rgba(15,28,53,0.14);
                        }

                        .page-ring-body #ring-size-result-label,
                        .page-ring-body #ring-compare-label {
                            color: #0f1c35;
                        }

                        .page-ring-body select,
                        .page-ring-body input[type="range"] {
                            outline: none;
                        }

                        .page-ring-body select {
                            border: 1px solid rgba(197,160,89,0.8);
                            background: #fff;
                        }

                        .page-ring-body .info-box strong {
                            color: #0f1c35;
                        }

                        @media (max-width: 767px) {
                            .page-ring-body .hero-cap h2 {
                                font-size: 36px;
                            }
                            .page-ring-body .yuzuk-olcer-card {
                                padding: 28px 20px;
                                min-height: auto;
                            }
                            .page-ring-body .wizard-steps {
                                flex-direction: column;
                                gap: 12px;
                            }
                            .page-ring-body .measure-tab-btn {
                                min-width: auto;
                                width: 100%;
                            }
                        }
                    </style>
                    <!-- Hero Area Start-->
                    <% if (typeof embed==='undefined' || !embed) { %>
                        <div class="slider-area ">
                            <div class="single-slider slider-height2 d-flex align-items-center">
                                <div class="container">
                                    <div class="row">
                                        <div class="col-xl-12">
                                            <div class="hero-cap text-center">
                                                <h2>Yüzük Ölçü Bulucu</h2>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% } %>

                            <!-- Finder Section Start -->
                            <section class="ring-size-section section_padding"
                                style="background-color: #ffffff; padding: <%= (typeof embed !== 'undefined' && embed) ? '0px 0' : '60px 0 100px' %>;">
                                <div class="container">
                                    <div class="row justify-content-center">
                                        <div class="col-lg-10 text-center mb-4">
                                            <div class="section-tittle text-center">
                                                <div style="margin-bottom: 20px;">
                                                    <div class="brand-label">
                                                        GİZ PİRLANTA</div>
                                                </div>
                                                <h2>1 TL ile Yüzük Ölçüsü Hesaplama</h2>
                                            </div>
                                            <p
                                                style="font-size: 15px; color: #777; max-width: 700px; margin: 15px auto 0; line-height: 1.6; font-family: 'Inter', sans-serif;">
                                                Markamıza özel interaktif kalibrasyon aracı sayesinde, ekranınızın
                                                boyutuna göre %100 hassasiyetle yüzük ölçünüzü anında
                                                hesaplayabilirsiniz.
                                            </p>
                                        </div>
                                    </div>

                                    <div class="row justify-content-center">
                                        <div class="col-lg-8 col-md-10">
                                            <div class="yuzuk-olcer-card"
                                                style="background: #ffffff; border-radius: 24px; box-shadow: 0 15px 40px rgba(0,0,0,0.06); padding: 35px 30px; border: 1px solid #ede8df; min-height: 580px; display: flex; flex-direction: column; justify-content: space-between; position: relative;">

                                                <!-- Step Indicator -->
                                                <div class="wizard-steps"
                                                    style="display: flex; justify-content: space-between; margin-bottom: 30px; position: relative; z-index: 2;">
                                                    <div class="step-item active" id="step-dot-1"
                                                        style="flex: 1; text-align: center; font-size: 13px; font-weight: 700; color: #c5a059;">
                                                        <div class="step-num"
                                                            style="width: 32px; height: 32px; border-radius: 50%; background: #c5a059; color: #fff; display: flex; align-items: center; justify-content: center; margin: 0 auto 8px; font-weight: bold; box-shadow: 0 4px 10px rgba(197, 160, 89, 0.3);">
                                                            1</div>
                                                        Giriş
                                                    </div>
                                                    <div class="step-item" id="step-dot-2"
                                                        style="flex: 1; text-align: center; font-size: 13px; font-weight: 500; color: #aaa;">
                                                        <div class="step-num"
                                                            style="width: 32px; height: 32px; border-radius: 50%; background: #eee; color: #888; display: flex; align-items: center; justify-content: center; margin: 0 auto 8px; font-weight: bold;">
                                                            2</div>
                                                        Kalibrasyon
                                                    </div>
                                                    <div class="step-item" id="step-dot-3"
                                                        style="flex: 1; text-align: center; font-size: 13px; font-weight: 500; color: #aaa;">
                                                        <div class="step-num"
                                                            style="width: 32px; height: 32px; border-radius: 50%; background: #eee; color: #888; display: flex; align-items: center; justify-content: center; margin: 0 auto 8px; font-weight: bold;">
                                                            3</div>
                                                        Ölçüm
                                                    </div>
                                                </div>

                                                <!-- Step Content 1: Welcome -->
                                                <div id="step-content-1" class="step-content"
                                                    style="text-align: center; margin-bottom: 20px;">
                                                    <div style="font-size: 60px; color: #c5a059; margin-bottom: 20px;">
                                                        <i class="fas fa-gem icon-large"></i></div>
                                                    <h3
                                                        style="font-size: 20px; font-weight: 700; color: #140C40; margin-bottom: 15px; font-family: 'Montserrat', sans-serif;">
                                                        Ölçünüzü Bulmak Çok Kolay!</h3>
                                                    <p
                                                        style="font-size: 14px; color: #666; line-height: 1.7; margin-bottom: 25px; max-width: 500px; margin-left: auto; margin-right: auto;">
                                                        Yüzük ölçünüzü tam olarak tespit etmek için elinizde **fiziksel
                                                        bir 1 TL madeni para** olması yeterlidir. Ekranınızı 1 TL ile
                                                        kalibre ederek yüzüklerinizin iç çapını milimetrik hassasiyetle
                                                        ölçeceğiz.
                                                    </p>
                                                    <div
                                                        style="background: #fdfaf4; border-radius: 12px; padding: 15px; border: 1px solid #f6ecdb; max-width: 450px; margin: 0 auto 30px; text-align: left; font-size: 13px; color: #8c7340; line-height: 1.5;">
                                                        <i class="fas fa-info-circle"
                                                            style="margin-right: 8px; font-size: 15px; vertical-align: middle;"></i>
                                                        <strong>Nasıl Çalışır?</strong> Her ekranın piksel yoğunluğu
                                                        farklıdır. 1 TL madeni paranın sabit olan <strong>26.15
                                                            mm</strong> çapını ekranda eşleyerek cihazınızın piksel
                                                        ölçeğini tanımlarız.
                                                    </div>
                                                    <button type="button" class="btn-premium-primary"
                                                        onclick="goToStep(2)"
                                                        style="max-width: 250px; margin: 0 auto; display: block; border-radius: 30px;">Hemen
                                                        Başla</button>
                                                </div>

                                                <!-- Step Content 2: Calibration -->
                                                <div id="step-content-2" class="step-content"
                                                    style="display: none; text-align: center;">
                                                    <h3
                                                        style="font-size: 18px; font-weight: 700; color: #140C40; margin-bottom: 10px; font-family: 'Montserrat', sans-serif;">
                                                        Ekran Kalibrasyonu</h3>
                                                    <p
                                                        style="font-size: 13px; color: #666; line-height: 1.5; margin-bottom: 25px; max-width: 520px; margin-left: auto; margin-right: auto;">
                                                        Ekranın üzerine fiziksel bir **1 TL** yerleştirin. Aşağıdaki
                                                        kaydırıcıyı kullanarak ekrandaki daireyi **1 TL madeni para ile
                                                        birebir aynı boyuta** getirin.
                                                    </p>

                                                    <!-- Calibration Interactive Area -->
                                                    <div
                                                        style="height: 180px; display: flex; align-items: center; justify-content: center; margin-bottom: 30px; position: relative;">
                                                        <div id="calibration-circle"
                                                            style="width: 240px; height: 240px; border-radius: 50%; background: radial-gradient(circle, rgba(197, 160, 89, 0.15) 0%, rgba(197, 160, 89, 0.45) 100%); border: 3px dashed #c5a059; transition: width 0.05s ease, height 0.05s ease; box-shadow: 0 10px 30px rgba(197,160,89,0.2); display: flex; align-items: center; justify-content: center;">
                                                            <div
                                                                style="font-size: 11px; font-weight: 700; color: #8c7340; text-shadow: 0 1px 1px #fff; text-transform: uppercase; letter-spacing: 0.5px;">
                                                                1 TL Koyun</div>
                                                        </div>
                                                    </div>

                                                    <!-- Slider & Fine Tuning Buttons -->
                                                    <div style="max-width: 450px; margin: 0 auto 25px;">
                                                        <div
                                                            style="display: flex; align-items: center; justify-content: space-between; gap: 15px; margin-bottom: 10px;">
                                                            <button type="button" class="btn-tune"
                                                                onclick="tuneCalibration(-1)"
                                                                style="width:36px; height:36px; border-radius:50%; border:1px solid #ccc; background:#fff; font-size:18px; font-weight:bold; color:#555; cursor:pointer; outline:none; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 5px rgba(0,0,0,0.05);">-</button>
                                                            <input type="range" id="calibration-slider" min="150"
                                                                max="350" value="240"
                                                                oninput="resizeCalibrationCircle(this.value)"
                                                                style="flex:1; height:6px; border-radius:5px; background:#e4cc95; outline:none; -webkit-appearance:none; cursor:pointer;">
                                                            <button type="button" class="btn-tune"
                                                                onclick="tuneCalibration(1)"
                                                                style="width:36px; height:36px; border-radius:50%; border:1px solid #ccc; background:#fff; font-size:18px; font-weight:bold; color:#555; cursor:pointer; outline:none; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 5px rgba(0,0,0,0.05);">+</button>
                                                        </div>
                                                        <span id="cal-pixels-label"
                                                            style="font-size: 12px; color: #999; font-family: monospace;">Genişlik:
                                                            240px</span>
                                                    </div>

                                                    <div
                                                        style="display: flex; gap: 15px; max-width: 400px; margin: 0 auto;">
                                                        <button type="button" class="btn-premium-secondary"
                                                            onclick="goToStep(1)"
                                                            style="border-radius:30px; padding: 12px 24px;">Geri
                                                            Git</button>
                                                        <button type="button" class="btn-premium-primary"
                                                            onclick="saveCalibrationAndContinue()"
                                                            style="border-radius:30px; padding: 12px 24px;">Kalibrasyonu
                                                            Tamamla</button>
                                                    </div>
                                                </div>

                                                <!-- Step Content 3: Measurement -->
                                                <div id="step-content-3" class="step-content"
                                                    style="display: none; text-align: center;">
                                                    <h3
                                                        style="font-size: 18px; font-weight: 700; color: #140C40; margin-bottom: 15px; font-family: 'Montserrat', sans-serif;">
                                                        Yüzük Ölçümü Yapın</h3>

                                                    <!-- Measurement Mode Tabs -->
                                                    <div
                                                        style="display: flex; justify-content: center; gap: 10px; margin-bottom: 25px;">
                                                        <button type="button" id="tab-btn-ring"
                                                            class="measure-tab-btn active"
                                                            onclick="switchMeasureMode('ring')"
                                                            style="padding:8px 18px; font-size:12px; font-weight:700; border-radius:20px; border:1px solid #c5a059; background:#c5a059; color:#fff; cursor:pointer; outline:none; transition: all 0.3s;">Mevcut
                                                            Yüzük ile Ölç</button>
                                                        <button type="button" id="tab-btn-circles"
                                                            class="measure-tab-btn"
                                                            onclick="switchMeasureMode('circles')"
                                                            style="padding:8px 18px; font-size:12px; font-weight:700; border-radius:20px; border:1px solid #ccc; background:#fff; color:#555; cursor:pointer; outline:none; transition: all 0.3s;">Ölçü
                                                            Seçip Karşılaştır</button>
                                                    </div>

                                                    <!-- Mode A: Measure Existing Ring -->
                                                    <div id="mode-content-ring" style="display: block;">
                                                        <p
                                                            style="font-size: 13px; color: #666; line-height: 1.5; margin-bottom: 20px; max-width: 500px; margin-left: auto; margin-right: auto;">
                                                            Yüzüğünüzü ekranın ortasındaki dairenin üzerine koyun.
                                                            Aşağıdaki kaydırıcıyla daireyi yüzüğünüzün **iç metal
                                                            kenarlarıyla** birebir hizalayın.
                                                        </p>

                                                        <!-- Ring Interactive Circle Area -->
                                                        <div
                                                            style="height: 180px; display: flex; align-items: center; justify-content: center; margin-bottom: 25px; position: relative;">
                                                            <div id="ring-measure-circle"
                                                                style="width: 160px; height: 160px; border-radius: 50%; border: 2.5px solid #140C40; background: transparent; transition: width 0.05s ease, height 0.05s ease; box-shadow: 0 0 15px rgba(20, 12, 64, 0.15); display: flex; align-items: center; justify-content: center;">
                                                                <div
                                                                    style="width: 100%; height: 100%; border-radius: 50%; border: 1px dashed #c5a059; opacity: 0.8;">
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <!-- Result Display Box -->
                                                        <div
                                                            style="background: #fcf9f2; border: 1px solid #e4cc95; border-radius: 16px; padding: 15px; max-width: 400px; margin: 0 auto 20px; display: flex; align-items: center; justify-content: space-between;">
                                                            <div style="text-align: left;">
                                                                <span
                                                                    style="font-size: 11px; color: #888; text-transform: uppercase; letter-spacing: 0.5px; font-weight: bold;">Tahmini
                                                                    Ölçünüz</span>
                                                                <h4 style="font-size: 26px; font-weight: 800; color: #c5a059; margin: 0;"
                                                                    id="ring-size-result-label">15</h4>
                                                            </div>
                                                            <div
                                                                style="text-align: right; border-left: 1px solid #ede8df; padding-left: 15px;">
                                                                <span
                                                                    style="font-size: 11px; color: #888; display: block; font-weight: 600;">İç
                                                                    Çap</span>
                                                                <span
                                                                    style="font-size: 14px; font-weight: 700; color: #140C40;"
                                                                    id="ring-diameter-result-label">17.52 mm</span>
                                                            </div>
                                                        </div>

                                                        <!-- Ring Slider & Fine Tuning Buttons -->
                                                        <div style="max-width: 450px; margin: 0 auto 25px;">
                                                            <div
                                                                style="display: flex; align-items: center; justify-content: space-between; gap: 15px;">
                                                                <button type="button" class="btn-tune"
                                                                    onclick="tuneRingMeasure(-1)"
                                                                    style="width:36px; height:36px; border-radius:50%; border:1px solid #ccc; background:#fff; font-size:18px; font-weight:bold; color:#555; cursor:pointer; outline:none; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 5px rgba(0,0,0,0.05);">-</button>
                                                                <input type="range" id="ring-measure-slider" min="100"
                                                                    max="250" value="160"
                                                                    oninput="resizeRingMeasureCircle(this.value)"
                                                                    style="flex:1; height:6px; border-radius:5px; background:#c5a059; outline:none; -webkit-appearance:none; cursor:pointer;">
                                                                <button type="button" class="btn-tune"
                                                                    onclick="tuneRingMeasure(1)"
                                                                    style="width:36px; height:36px; border-radius:50%; border:1px solid #ccc; background:#fff; font-size:18px; font-weight:bold; color:#555; cursor:pointer; outline:none; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 5px rgba(0,0,0,0.05);">+</button>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <!-- Mode B: Choose Size and Display -->
                                                    <div id="mode-content-circles" style="display: none;">
                                                        <p
                                                            style="font-size: 13px; color: #666; line-height: 1.5; margin-bottom: 25px; max-width: 500px; margin-left: auto; margin-right: auto;">
                                                            Aşağıdan öğrenmek istediğiniz **yüzük ölçüsünü** seçin.
                                                            Ekranda tam olarak o ölçünün birebir fiziksel boyutundaki
                                                            daire çizilecektir.
                                                        </p>

                                                        <!-- Selection Dropdown -->
                                                        <div style="max-width: 300px; margin: 0 auto 25px;">
                                                            <label
                                                                style="display:block; font-size:12px; font-weight:700; color:#c5a059; text-transform:uppercase; margin-bottom:8px; text-align:left;">Ölçü
                                                                Seçin</label>
                                                            <select id="size-comparator-select"
                                                                onchange="updateComparatorSize(this.value)"
                                                                style="width: 100%; padding: 12px; border: 1px solid #c5a059; border-radius: 8px; font-size: 14px; font-weight: 700; color: #140C40; outline: none; background: #fff; cursor: pointer; box-shadow: 0 4px 10px rgba(197, 155, 69, 0.05);">
                                                                <!-- Will be populated dynamically -->
                                                            </select>
                                                        </div>

                                                        <!-- Comparison Circle Area -->
                                                        <div
                                                            style="height: 160px; display: flex; align-items: center; justify-content: center; margin-bottom: 25px; position: relative;">
                                                            <div id="ring-compare-circle"
                                                                style="width: 160px; height: 160px; border-radius: 50%; border: 3px solid #c5a059; background: radial-gradient(circle, rgba(197,160,89,0.05) 0%, rgba(197,160,89,0.15) 100%); display: flex; align-items: center; justify-content: center; transition: width 0.15s ease, height 0.15s ease;">
                                                                <div style="font-size: 18px; font-weight: 800; color: #140C40;"
                                                                    id="ring-compare-label">15</div>
                                                            </div>
                                                        </div>

                                                        <div style="margin-bottom: 20px;">
                                                            <span
                                                                style="font-size: 13px; color: #888; font-weight: 600;">Seçilen
                                                                Ölçü İç Çapı: <strong style="color:#140C40;"
