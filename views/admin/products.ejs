    <script>
        let dragSourceElement = null;

        function handleDragStart(e) {
            this.style.opacity = '0.4';
            dragSourceElement = this;
            e.dataTransfer.effectAllowed = 'move';
            e.dataTransfer.setData('text/html', this.innerHTML);
        }

        function handleDragOver(e) {
            if (e.preventDefault) {
                e.preventDefault();
            }
            e.dataTransfer.dropEffect = 'move';
            return false;
        }

        function handleDrop(e) {
            if (e.stopPropagation) {
                e.stopPropagation();
            }

            if (dragSourceElement !== this) {
                // Swap content and dataset
                const tempHTML = this.innerHTML;
                const tempType = this.dataset.type;
                const tempUrl = this.dataset.url;

                this.innerHTML = dragSourceElement.innerHTML;
                this.dataset.type = dragSourceElement.dataset.type;
                this.dataset.url = dragSourceElement.dataset.url;

                dragSourceElement.innerHTML = tempHTML;
                dragSourceElement.dataset.type = tempType;
                dragSourceElement.dataset.url = tempUrl;

                const container = this.parentElement || dragSourceElement.parentElement;
                if (container && container.id === 'createMediaContainer') {
                    serializeCreateMediaState();
                } else {
                    serializeMediaState();
                }
            }
            return false;
        }

        function handleDragEnd(e) {
            this.style.opacity = '1';
            const container = this.parentElement;
            if (container && container.id === 'createMediaContainer') {
                serializeCreateMediaState();
            } else {
                serializeMediaState();
            }
        }

        function removeMediaItem(button) {
            const item = button.closest('.draggable-media-item');
            if (!item) return;
            const container = item.parentElement;
            const isEdit = (container && container.id === 'editMediaContainer');

            if (item.dataset.type === 'video' && isEdit) {
                document.getElementById('deleteVideoInput').value = 'true';
            }
            item.remove();

            if (container.querySelectorAll('.draggable-media-item').length === 0) {
                if (isEdit) {
                    container.innerHTML = '<span class="text-muted w-100 text-center">Bu ürünün henüz galeri görseli veya videosu yok.</span>';
                } else {
                    container.innerHTML = '<span class="text-muted w-100 text-center" id="createMediaEmptyText">Henüz galeri görseli veya videosu eklenmedi.</span>';
                }
            }

            if (isEdit) {
                serializeMediaState();
            } else {
                serializeCreateMediaState();
            }
        }

        function serializeMediaState() {
            const container = document.getElementById('editMediaContainer');
            const hiddenContainer = document.getElementById('editMediaHiddenInputs');
            if (!container || !hiddenContainer) return;
            hiddenContainer.innerHTML = '';

            const items = container.querySelectorAll('.draggable-media-item');
            items.forEach((item, index) => {
                if (item.dataset.type === 'image') {
                    const inputUrl = document.createElement('input');
                    inputUrl.type = 'hidden';
                    inputUrl.name = 'existingImages';
                    inputUrl.value = item.dataset.url;
                    hiddenContainer.appendChild(inputUrl);

                    const inputOrder = document.createElement('input');
                    inputOrder.type = 'hidden';
                    inputOrder.name = 'existingImagesOrder';
                    inputOrder.value = index;
                    hiddenContainer.appendChild(inputOrder);
                } else if (item.dataset.type === 'video') {
                    // Video URL'si de kaydedilmeli
                    const inputVideoUrl = document.createElement('input');
                    inputVideoUrl.type = 'hidden';
                    inputVideoUrl.name = 'videoUrl';
                    inputVideoUrl.value = item.dataset.url;
                    hiddenContainer.appendChild(inputVideoUrl);

                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'videoOrder';
                    input.value = index;
                    hiddenContainer.appendChild(input);
                }
            });
        }

        function serializeCreateMediaState() {
            const container = document.getElementById('createMediaContainer');
            const hiddenContainer = document.getElementById('createMediaHiddenInputs');
            if (!container || !hiddenContainer) return;
            hiddenContainer.innerHTML = '';

            const items = container.querySelectorAll('.draggable-media-item');
            items.forEach((item, index) => {
                if (item.dataset.type === 'image') {
                    const inputUrl = document.createElement('input');
                    inputUrl.type = 'hidden';
                    inputUrl.name = 'existingImages';
                    inputUrl.value = item.dataset.url;
                    hiddenContainer.appendChild(inputUrl);

                    const inputOrder = document.createElement('input');
                    inputOrder.type = 'hidden';
                    inputOrder.name = 'existingImagesOrder';
                    inputOrder.value = index;
                    hiddenContainer.appendChild(inputOrder);
                } else if (item.dataset.type === 'video') {
                    // Video Cloudinary URL'si hidden input olarak gönderilir
                    const inputVideoUrl = document.createElement('input');
                    inputVideoUrl.type = 'hidden';
                    inputVideoUrl.name = 'videoUrl';
                    inputVideoUrl.value = item.dataset.url;
                    hiddenContainer.appendChild(inputVideoUrl);

                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'videoOrder';
                    input.value = index;
                    hiddenContainer.appendChild(input);
                }
            });
        }

        function populateEditProduct(product) {
            document.getElementById('editProductForm').action = '/admin/products/edit/' + product._id;
            document.getElementById('editProductName').value = product.name;
            document.getElementById('editProductDescription').value = product.description;
            document.getElementById('editProductPrice').value = product.price;
            document.getElementById('editProductStock').value = product.stock;

            // Set multiple selected categories if available
            try {
                const sel = document.getElementById('editProductCategory');
                for (let i = 0; i < sel.options.length; i++) sel.options[i].selected = false;
                if (product.categories && product.categories.length > 0) {
                    product.categories.forEach(cat => {
                        const val = cat._id || cat;
                        for (let i = 0; i < sel.options.length; i++) {
                            if (sel.options[i].value === (val.toString ? val.toString() : val)) sel.options[i].selected = true;
                        }
                    });
                } else if (product.category) {
                    const val = product.category._id || product.category;
                    for (let i = 0; i < sel.options.length; i++) {
                        if (sel.options[i].value === (val.toString ? val.toString() : val)) sel.options[i].selected = true;
                    }
                }
            } catch (e) { }

            document.getElementById('editProductIsPopular').checked = product.isPopular;
            document.getElementById('deleteVideoInput').value = 'false';

            // Mücevher alanlarını doldur
            document.getElementById('editProductCode').value = product.productCode || '';
            document.getElementById('editCertificate').value = product.certificate || '';
            document.getElementById('editMetal').value = product.metal || '';
            document.getElementById('editMetalColor').value = product.metalColor || '';
            document.getElementById('editGemType').value = product.gemType || '';
            document.getElementById('editCaratWeight').value = (product.caratWeight !== null && product.caratWeight !== undefined) ? product.caratWeight : '';
            document.getElementById('editGemColor').value = product.gemColor || '';
            document.getElementById('editGemClarity').value = product.gemClarity || '';
            document.getElementById('editGemCut').value = product.gemCut || '';


            let mediaList = [];
            if (product.images && product.images.length > 0) {
                product.images.forEach(img => {
                    mediaList.push({ type: 'image', url: img.url, order: img.order || 0 });
                });
            }
            if (product.videoUrl) {
                let vOrder = (product.videoOrder !== undefined && product.videoOrder !== null) ? product.videoOrder : 99;
                mediaList.push({ type: 'video', url: product.videoUrl, order: vOrder });
            }

            mediaList.sort((a, b) => a.order - b.order);

            const container = document.getElementById('editMediaContainer');
            container.innerHTML = '';

            if (mediaList.length === 0) {
                container.innerHTML = '<span class="text-muted w-100 text-center">Bu ürünün henüz galeri görseli veya videosu yok.</span>';
            } else {
                mediaList.forEach(media => {
                    const itemEl = document.createElement('div');
                    itemEl.className = `position-relative draggable-media-item ${media.type === 'video' ? 'border border-primary rounded shadow-sm' : 'border border-light rounded shadow-sm'}`;
                    itemEl.style.width = '80px';
                    itemEl.style.height = '80px';
                    itemEl.style.cursor = 'move';
                    itemEl.draggable = true;
                    itemEl.dataset.type = media.type;
                    itemEl.dataset.url = media.url;

                    let innerHTML = '';
                    if (media.type === 'image') {
                        innerHTML = `
                        <img src="${media.url}" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;">
                        <button type="button" class="btn btn-sm btn-danger position-absolute" style="top: -5px; right: -5px; padding: 2px 6px; border-radius: 50%; font-size: 10px; z-index: 10;" onclick="removeMediaItem(this)">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    `;
                    } else {
                        innerHTML = `
                        <div class="bg-dark text-white d-flex flex-column align-items-center justify-content-center" style="width: 100%; height: 100%; border-radius: 8px;">
                            <i class="fas fa-video fa-lg gold-text mb-1"></i>
                            <span style="font-size: 9px; font-weight: bold; letter-spacing: 0.5px;">VİDEO</span>
                        </div>
                        <button type="button" class="btn btn-sm btn-danger position-absolute" style="top: -5px; right: -5px; padding: 2px 6px; border-radius: 50%; font-size: 10px; z-index: 10;" onclick="removeMediaItem(this)">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    `;
                    }
                    itemEl.innerHTML = innerHTML;

                    itemEl.addEventListener('dragstart', handleDragStart);
                    itemEl.addEventListener('dragover', handleDragOver);
                    itemEl.addEventListener('drop', handleDrop);
                    itemEl.addEventListener('dragend', handleDragEnd);

                    container.appendChild(itemEl);
                });
            }

            serializeMediaState();

            // Coklu Karat Seceneklerini doldur
            const editCaratContainer = document.getElementById('editCaratOptionsContainer');
            editCaratContainer.innerHTML = '';
            if (product.caratOptions && product.caratOptions.length > 0) {
                product.caratOptions.forEach(opt => {
                    addCaratOptionRow(editCaratContainer, opt.carat, opt.price);
                });
            }
        }

        // AJAX ile dosyay\u0131 Cloudinary'ye y\u00fckler ve thumbnail olu\u015fturur
        function uploadAndAddMedia(file, container, isEdit, mediaType) {
            // \u00d6nce y\u00fckleniyor g\u00f6stergesi ekle
            const loadingEl = document.createElement('div');
            loadingEl.className = 'position-relative border border-light rounded shadow-sm d-flex align-items-center justify-content-center bg-light';
            loadingEl.style.cssText = 'width:80px;height:80px;flex-shrink:0;';
            loadingEl.innerHTML = '<i class="fas fa-spinner fa-spin text-primary fa-lg"></i>';
            const emptyCreate = document.getElementById('createMediaEmptyText');
            if (emptyCreate) emptyCreate.remove();
            const emptyEdit = container.querySelector('.text-muted');
            if (emptyEdit && (emptyEdit.innerText.includes('Hen\u00fcz') || emptyEdit.innerText.includes('Bu \u00fcr\u00fcn'))) {
                container.innerHTML = '';
            }
            container.appendChild(loadingEl);

            const formData = new FormData();
            formData.append('file', file);

            $.ajax({
                url: '/admin/upload-temp',
                method: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (response) {
                    loadingEl.remove();
                    if (!response.success) {
                        alert('Y\u00fckleme hatas\u0131: ' + (response.message || 'Bilinmeyen hata'));
                        return;
                    }
                    const url = response.url;
                    const itemEl = document.createElement('div');
                    itemEl.className = 'position-relative draggable-media-item border border-light rounded shadow-sm';
                    itemEl.style.cssText = 'width:80px;height:80px;cursor:move;flex-shrink:0;';
                    itemEl.draggable = true;
                    itemEl.dataset.type = mediaType;
                    itemEl.dataset.url = url;

                    if (mediaType === 'image') {
                        itemEl.innerHTML = `
                        <img src="${url}" style="width:100%;height:100%;object-fit:cover;border-radius:8px;">
                        <button type="button" class="btn btn-sm btn-danger position-absolute" style="top:-5px;right:-5px;padding:2px 6px;border-radius:50%;font-size:10px;z-index:10;" onclick="removeMediaItem(this)">
                            <i class="fas fa-trash-alt"></i>
                        </button>`;
                    } else {
                        itemEl.innerHTML = `
                        <div class="bg-dark text-white d-flex flex-column align-items-center justify-content-center" style="width:100%;height:100%;border-radius:8px;">
                            <i class="fas fa-video fa-lg text-primary mb-1"></i>
                            <span style="font-size:8px;font-weight:bold;color:#007bff;">V\u0130DEO</span>
                        </div>
                        <button type="button" class="btn btn-sm btn-danger position-absolute" style="top:-5px;right:-5px;padding:2px 6px;border-radius:50%;font-size:10px;z-index:10;" onclick="removeMediaItem(this)">
                            <i class="fas fa-trash-alt"></i>
                        </button>`;
                    }

                    itemEl.addEventListener('dragstart', handleDragStart);
                    itemEl.addEventListener('dragover', handleDragOver);
                    itemEl.addEventListener('drop', handleDrop);
                    itemEl.addEventListener('dragend', handleDragEnd);
                    container.appendChild(itemEl);

                    if (isEdit) {
                        serializeMediaState();
                    } else {
                        serializeCreateMediaState();
                    }
                },
                error: function () {
                    loadingEl.remove();
                    alert('Cloudinary y\u00fckleme hatas\u0131 olu\u015ftu. \u0130nternet ba\u011flant\u0131n\u0131z\u0131 kontrol edin.');
                }
            });
        }

        // Helper function to compress images on the client side before upload to prevent Cloudinary 10MB size limits
        function compressImage(file, callback) {
            if (!file || !file.type.startsWith('image/')) {
                callback(file);
                return;
            }
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = function (event) {
                const img = new Image();
                img.src = event.target.result;
                img.onload = function () {
                    const canvas = document.createElement('canvas');
                    let width = img.width;
                    let height = img.height;
                    const MAX_WIDTH = 1200;
                    const MAX_HEIGHT = 1200;

                    if (width > height) {
                        if (width > MAX_WIDTH) {
                            height *= MAX_WIDTH / width;
                            width = MAX_WIDTH;
                        }
                    } else {
                        if (height > MAX_HEIGHT) {
                            width *= MAX_HEIGHT / height;
                            height = MAX_HEIGHT;
                        }
                    }

                    canvas.width = width;
                    canvas.height = height;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, width, height);

                    canvas.toBlob(function (blob) {
                        const compressedFile = new File([blob], file.name, {
                            type: 'image/jpeg',
                            lastModified: Date.now()
                        });
                        if (compressedFile.size < file.size) {
                            callback(compressedFile);
                        } else {
                            callback(file);
                        }
                    }, 'image/jpeg', 0.8); // 80% JPEG quality is excellent and lightweight
                };
            };
            reader.onerror = function () {
                callback(file);
            };
        }

        // ADD modal — galeri görselleri seçince AJAX ile Cloudinary'ye yükle (sıkıştırılmış olarak)
        $('#galleryFiles').on('change', function (e) {
            const files = e.target.files;
            if (!files || files.length === 0) return;
            const container = document.getElementById('createMediaContainer');
            Array.from(files).forEach(file => {
                compressImage(file, function (compressedFile) {
                    uploadAndAddMedia(compressedFile, container, false, 'image');
                });
            });
            $(this).next('.custom-file-label').addClass('selected').html(files.length + ' görsel yükleniyor...');
            this.value = ''; // Input'u sıfırla
        });

        // ADD modal — video seçince AJAX ile Cloudinary'ye yükle
        $('#videoFile').on('change', function (e) {
            const file = e.target.files[0];
            if (!file) return;
            const container = document.getElementById('createMediaContainer');
            // Varsa eski video thumbnailını kaldır
            container.querySelectorAll('.draggable-media-item[data-type="video"]').forEach(el => el.remove());
            uploadAndAddMedia(file, container, false, 'video');
            $(this).next('.custom-file-label').addClass('selected').html(file.name + ' yükleniyor...');
            this.value = '';
        });

        // EDIT modal — yeni galeri görselleri seçince AJAX ile Cloudinary'ye yükle (sıkıştırılmış olarak)
        $('#editGalleryFiles').on('change', function (e) {
            const files = e.target.files;
            if (!files || files.length === 0) return;
            const container = document.getElementById('editMediaContainer');
            Array.from(files).forEach(file => {
                compressImage(file, function (compressedFile) {
                    uploadAndAddMedia(compressedFile, container, true, 'image');
                });
            });
            $(this).next('.custom-file-label').addClass('selected').html(files.length + ' görsel yükleniyor...');
            this.value = '';
