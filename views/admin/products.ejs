<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ürün Yönetimi | Admin Paneli</title>
    <link rel="stylesheet" href="/assets/css/bootstrap.min.css">
    <link rel="stylesheet" href="/assets/css/fontawesome-all.min.css">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f8f9fa;
        }

        .sidebar {
            min-height: 100vh;
            background: #2c3e50;
            color: white;
            padding-top: 20px;
        }

        .sidebar a {
            color: #bdc3c7;
            display: block;
            padding: 15px;
            text-decoration: none;
            transition: 0.3s;
        }

        .sidebar a:hover,
        .sidebar a.active {
            background: #34495e;
            color: white;
            border-left: 4px solid #d4af37;
        }

        .main-content {
            padding: 30px;
        }

        .gold-text {
            color: #d4af37;
        }
    </style>
</head>

<body>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-2 sidebar">
                <h4 class="text-center gold-text mb-4">Yönetim Paneli</h4>
                <a href="/admin"><i class="fas fa-tachometer-alt mr-2"></i> Dashboard</a>
                <a href="/admin/home-settings"><i class="fas fa-home mr-2"></i> Ana Sayfa Yönetimi</a>
                <a href="/admin/products-management" class="active"><i class="fas fa-gem mr-2"></i> Ürünler</a>
                <a href="/admin/categories"><i class="fas fa-list mr-2"></i> Kategoriler</a>
                <a href="/admin/orders"><i class="fas fa-shopping-cart mr-2"></i> Siparişler</a>
                <a href="/admin/users"><i class="fas fa-users mr-2"></i> Kullanıcılar</a>
                <a href="/admin/support"><i class="fas fa-comments mr-2"></i> Canlı Destek</a>
                <a href="/admin/banners"><i class="fas fa-image mr-2"></i> Bannerlar</a>
                <a href="/"><i class="fas fa-external-link-alt mr-2"></i> Siteye Git</a>
                <a href="/auth/logout" class="mt-5 text-danger"><i class="fas fa-sign-out-alt mr-2"></i> Çıkış Yap</a>
            </div>

            <!-- Main Content -->
            <div class="col-md-10 main-content">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2>Ürün Yönetimi</h2>
                    <button class="btn btn-warning" data-toggle="modal" data-target="#addProductModal">Yeni Ürün
                        Ekle</button>
                </div>

                <% const msg=typeof query !=='undefined' ? query.msg : (typeof locals !=='undefined' && locals.msg ?
                    locals.msg : null); %>
                    <% const urlMsg=(function(){ try { return new URL(require ? 'http://x' : 'http://x' ).searchParams;
                        } catch(e){ return null; } })(); %>
                        <script>
                            (function () {
                                const p = new URLSearchParams(window.location.search);
                                const msg = p.get('msg');
                                if (msg === 'success') {
                                    document.addEventListener('DOMContentLoaded', function () {
                                        showAdminAlert('Ürün başarıyla kaydedildi!', 'success');
                                    });
                                } else if (msg === 'doc_too_large') {
                                    document.addEventListener('DOMContentLoaded', function () {
                                        showAdminAlert('⚠️ Görseller çok büyük! Lütfen daha az veya daha küçük resim ekleyin (max ~4 resim tavsiye edilir).', 'danger');
                                    });
                                } else if (msg === 'video_too_large') {
                                    document.addEventListener('DOMContentLoaded', function () {
                                        showAdminAlert('⚠️ Video çok büyük! Lütfen 8MB altında bir video yükleyin.', 'danger');
                                    });
                                } else if (msg === 'error') {
                                    document.addEventListener('DOMContentLoaded', function () {
                                        showAdminAlert('Bir hata oluştu, lütfen tekrar deneyin.', 'danger');
                                    });
                                }
                                function showAdminAlert(text, type) {
                                    const div = document.createElement('div');
                                    div.className = 'alert alert-' + type + ' alert-dismissible fade show';
                                    div.innerHTML = text + '<button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>';
                                    const content = document.querySelector('.main-content');
                                    if (content) content.insertBefore(div, content.firstChild);
                                }
                            })();
                        </script>

                        <div class="card border-none shadow-sm">
                            <div class="card-body">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Görsel</th>
                                            <th>Ürün Adı</th>
                                            <th>Kategori</th>
                                            <th>Fiyat</th>
                                            <th>Stok</th>
                                            <th>İşlemler</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% products.forEach(product=> { %>
                                            <tr>
                                                <td><img src="<%= product.imageUrl %>" width="50" alt=""></td>
                                                <td>
                                                    <%= product.name %>
                                                </td>
                                                <td>
                                                    <% if (product.categories && product.categories.length> 0) { %>
                                                        <%= product.categories.map(c=> (c.name ? c.name : (c.toString ?
                                                            c.toString() : ''))).join(', ') %>
                                                            <% } else if (product.category) { %>
                                                                <%= product.category.name %>
                                                                    <% } else { %>
                                                                        Kategorisiz
                                                                        <% } %>
                                                </td>
                                                <td>₺<%= product.price.toLocaleString('tr-TR') %>
                                                </td>
                                                <td>
                                                    <%= product.stock %>
                                                </td>
                                                <td>
                                                    <button class="btn btn-sm btn-warning mr-2" data-toggle="modal"
                                                        data-target="#editProductModal"
                                                        data-product='<%- JSON.stringify(product).replace(/'/g, "\\'") %>'
                                                        onclick="populateEditProduct(JSON.parse(this.getAttribute('data-product')));"><i class="fas fa-edit"></i></button>
                                                    <a href="/admin/products/delete/<%= product._id %>"
                                                        class="btn btn-sm btn-danger"
                                                        onclick="return confirm('Silmek istediğinize emin misiniz?')"><i
                                                            class="fas fa-trash"></i></a>
                                                </td>
                                            </tr>
                                            <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
            </div>
        </div>
    </div>

    <!-- Add Product Modal -->
    <div class="modal fade" id="addProductModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Yeni Ürün Ekle</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <form action="/admin/products/add" method="POST" enctype="multipart/form-data" novalidate onsubmit="return validateProductForm(this)">
                    <div class="modal-body">
                        <!-- Sekmeler -->
                        <ul class="nav nav-tabs mb-3" id="addProductTabs" role="tablist">
                            <li class="nav-item"><a class="nav-link active" data-toggle="tab" href="#addTab1">Temel
                                    Bilgiler</a></li>
                            <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#addTab2">💎 Taş &
                                    Maden</a></li>
                            <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#addTab3">📸 Görseller</a>
                            </li>
                        </ul>
                        <div class="tab-content">
                            <!-- Sekme 1: Temel Bilgiler -->
                            <div class="tab-pane fade show active" id="addTab1">
                                <div class="form-group">
                                    <label>Ürün Adı</label>
                                    <input type="text" name="name" class="form-control" required>
                                </div>
                                <div class="form-group">
                                    <label>Açıklama</label>
                                    <textarea name="description" class="form-control" rows="3" required></textarea>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Fiyat (₺)</label>
                                            <input type="number" name="price" class="form-control" required>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Stok</label>
                                            <input type="number" name="stock" class="form-control" value="1" required>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>Kategoriler (Birden fazla seçebilirsiniz)</label>
                                    <select name="categories" class="form-control" multiple required
                                        style="height:140px;">
                                        <% categories.forEach(cat=> { %>
                                            <option value="<%= cat._id %>">
                                                <%= cat.name %>
                                            </option>
                                            <% }); %>
                                    </select>
                                    <small class="text-muted">Ctrl / Cmd ile birden fazla kategori
                                        seçebilirsiniz.</small>
                                </div>
                                <div class="form-check mb-3">
                                    <input type="checkbox" name="isPopular" class="form-check-input" id="isPopular">
                                    <label class="form-check-label" for="isPopular">Öne Çıkan Ürün (Ana Sayfada
                                        Göster)</label>
                                </div>
                            </div>
                            <!-- Sekme 2: Taş & Maden Bilgileri -->
                            <div class="tab-pane fade" id="addTab2">
                                <p class="text-muted small mb-3"><i class="fas fa-info-circle"></i> Tüm alanlar isteğe
                                    bağlıdır. Boş bırakılan alanlar ürün sayfasında gösterilmez.</p>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Ürün Kodu</label>
                                            <input type="text" name="productCode" class="form-control"
                                                placeholder="YZ-ALT-RO-1CT-14-Y-123-S">
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Sertifika</label>
                                            <select name="certificate" class="form-control">
                                                <option value="">-- Seçin (İsteğe Bağlı) --</option>
                                                <option value="IGI">IGI</option>
                                                <option value="GIA">GIA</option>
                                                <option value="HRD">HRD</option>
                                                <option value="Sertifikasız">Sertifikasız</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Maden</label>
                                            <select name="metal" class="form-control">
                                                <option value="">-- Seçin --</option>
                                                <option value="14k Altın">14k Altın</option>
                                                <option value="18k Altın">18k Altın</option>
                                                <option value="Gümüş">Gümüş</option>
                                                <option value="Platin">Platin</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Maden Rengi</label>
                                            <select name="metalColor" class="form-control">
                                                <option value="">-- Seçin --</option>
                                                <option value="Sarı Altın">Sarı Altın</option>
                                                <option value="Beyaz Altın">Beyaz Altın</option>
                                                <option value="Rose Gold">Rose Gold</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Değerli Taş Tipi</label>
                                            <select name="gemType" class="form-control">
                                                <option value="">-- Seçin --</option>
                                                <option value="Lab. Pırlanta">Lab. Pırlanta</option>
                                                <option value="Doğal Pırlanta">Doğal Pırlanta</option>
                                                <option value="Yakut">Yakut</option>
                                                <option value="Zümrüt">Zümrüt</option>
                                                <option value="Safir">Safir</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Tek Karat Ağırlığı (ct) <small class="text-muted">(Çoklu seçenek
                                                    yoksa)</small></label>
                                            <input type="number" name="caratWeight" class="form-control"
                                                placeholder="Örn: 1.08" step="0.01" min="0">
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <div class="form-group border p-3 rounded" style="background-color: #fcfcfc;">
                                            <label
                                                class="font-weight-bold d-flex justify-content-between align-items-center mb-2">
                                                <span>Çoklu Karat & Fiyat Seçenekleri <small class="text-muted">(Karata
                                                        göre fiyat değişsin istiyorsanız burayı doldurun)</small></span>
                                                <button type="button" class="btn btn-sm btn-outline-warning"
                                                    id="addCaratOptionBtn">
                                                    <i class="fas fa-plus"></i> Seçenek Ekle
                                                </button>
                                            </label>
                                            <div id="caratOptionsContainer" class="d-flex flex-column gap-2">
                                                <!-- Dinamik satırlar buraya eklenecek -->
                                            </div>
                                            <small class="text-muted mt-1 d-block"><i class="fas fa-info-circle"></i>
                                                Kullanıcı ürün detay sayfasında karat seçince buradaki fiyat aktif olur.
                                                Boş bırakırsanız sadece yukarıdaki fiyat geçerlidir.</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>Taş Rengi</label>
                                            <select name="gemColor" class="form-control">
                                                <option value="">-- Seçin --</option>
                                                <option value="D">D</option>
                                                <option value="E">E</option>
                                                <option value="F">F</option>
                                                <option value="G">G</option>
                                                <option value="H">H</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>Berraklık</label>
                                            <select name="gemClarity" class="form-control">
                                                <option value="">-- Seçin --</option>
                                                <option value="IF">IF</option>
                                                <option value="VVS1">VVS1</option>
                                                <option value="VVS2">VVS2</option>
                                                <option value="VS1">VS1</option>
                                                <option value="VS2">VS2</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>Kesim / Şekil</label>
                                            <select name="gemCut" class="form-control">
                                                <option value="">-- Seçin --</option>
                                                <option value="Round">Round</option>
                                                <option value="Marquise">Marquise</option>
                                                <option value="Oval">Oval</option>
                                                <option value="Princess">Princess</option>
                                                <option value="Pear">Pear</option>
                                                <option value="Emerald">Emerald</option>
                                                <option value="Cushion">Cushion</option>
                                                <option value="Heart">Heart</option>
                                                <option value="Radiant">Radiant</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Sekme 3: Görseller -->
                            <div class="tab-pane fade" id="addTab3">
                                <div class="form-group">
                                    <label>Ana Görsel (Katalog Resmi)</label>
                                    <div class="custom-file mb-3">
                                        <input type="file" class="custom-file-input" id="customFile" name="imageFile"
                                            accept="image/*" required>
                                        <label class="custom-file-label" for="customFile">Dosya Seçin veya
                                            Sürükleyin...</label>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>Galeri Görselleri <small class="text-muted">(Birden fazla seçilebilir —
                                            sürükleyerek sıralayın)</small></label>
                                    <div class="custom-file mb-3">
                                        <!-- name yok: AJAX ile Cloudinary'ye yüklenir, hidden input ile gönderilir -->
                                        <input type="file" class="custom-file-input" id="galleryFiles" accept="image/*"
                                            multiple>
                                        <label class="custom-file-label" for="galleryFiles">Birden Fazla Dosya
                                            Seçebilirsiniz...</label>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>Ürün Tanıtım Videosu <small class="text-muted">(İsteğe Bağlı)</small></label>
                                    <div class="custom-file mb-3">
                                        <!-- name yok: AJAX ile Cloudinary'ye yüklenir, hidden input ile gönderilir -->
                                        <input type="file" class="custom-file-input" id="videoFile"
                                            accept="video/mp4,video/webm">
                                        <label class="custom-file-label" for="videoFile">MP4 veya WebM Video
                                            Seçin...</label>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="font-weight-bold gold-text">Galeri & Video Sıralaması <small
                                            class="text-muted">(Sürükleyerek sıralayın)</small></label>
                                    <div id="createMediaContainer" class="d-flex flex-wrap gap-2 mt-3"
                                        style="min-height: 80px; border: 1px dashed #ced4da; border-radius: 8px; padding: 10px; background-color: #fcfcfc;">
                                        <span class="text-muted w-100 text-center" id="createMediaEmptyText">Henüz
                                            görsel veya video eklenmedi.</span>
                                    </div>
                                    <div id="createMediaHiddenInputs"></div>
                                </div>
                            </div>
                        </div>
                    </div>

            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-dismiss="modal">İptal</button>
            <button type="submit" class="btn btn-warning">Ürünü Kaydet</button>
        </div>
        </form>
    </div>
    </div>
    </div>

    <!-- Edit Product Modal -->
    <div class="modal fade" id="editProductModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Ürün Düzenle</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <form id="editProductForm" action="" method="POST" enctype="multipart/form-data" novalidate onsubmit="return validateProductForm(this)">
                    <div class="modal-body">
                        <!-- Sekmeler -->
                        <ul class="nav nav-tabs mb-3" id="editProductTabs" role="tablist">
                            <li class="nav-item"><a class="nav-link active" data-toggle="tab" href="#editTab1">Temel
                                    Bilgiler</a></li>
                            <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#editTab2">💎 Taş &
                                    Maden</a></li>
                            <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#editTab3">📸 Görseller</a>
                            </li>
                        </ul>
                        <div class="tab-content">
                            <!-- Sekme 1: Temel Bilgiler -->
                            <div class="tab-pane fade show active" id="editTab1">
                                <div class="form-group">
                                    <label>Ürün Adı</label>
                                    <input type="text" id="editProductName" name="name" class="form-control" required>
                                </div>
                                <div class="form-group">
                                    <label>Açıklama</label>
                                    <textarea id="editProductDescription" name="description" class="form-control"
                                        rows="3" required></textarea>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Fiyat (₺)</label>
                                            <input type="number" id="editProductPrice" name="price" class="form-control"
                                                required>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Stok</label>
                                            <input type="number" id="editProductStock" name="stock" class="form-control"
                                                required>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>Kategoriler (Birden fazla seçebilirsiniz)</label>
                                    <select id="editProductCategory" name="categories" class="form-control" multiple
                                        required style="height:140px;">
                                        <% categories.forEach(cat=> { %>
                                            <option value="<%= cat._id %>">
                                                <%= cat.name %>
                                            </option>
                                            <% }); %>
                                    </select>
                                    <small class="text-muted">Ctrl / Cmd ile birden fazla kategori
                                        seçebilirsiniz.</small>
                                </div>
                                <div class="form-check mb-3">
                                    <input type="checkbox" name="isPopular" class="form-check-input"
                                        id="editProductIsPopular">
                                    <label class="form-check-label" for="editProductIsPopular">Öne Çıkan Ürün (Ana
                                        Sayfada Göster)</label>
                                </div>
                            </div>
                            <!-- Sekme 2: Taş & Maden -->
                            <div class="tab-pane fade" id="editTab2">
                                <p class="text-muted small mb-3"><i class="fas fa-info-circle"></i> Tüm alanlar isteğe
                                    bağlıdır. Boş bırakılan alanlar ürün sayfasında gösterilmez.</p>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Ürün Kodu</label>
                                            <input type="text" id="editProductCode" name="productCode"
                                                class="form-control" placeholder="YZ-ALT-RO-1CT-14-Y-123-S">
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Sertifika</label>
                                            <select id="editCertificate" name="certificate" class="form-control">
                                                <option value="">-- Seçin (İsteğe Bağlı) --</option>
                                                <option value="IGI">IGI</option>
                                                <option value="GIA">GIA</option>
                                                <option value="HRD">HRD</option>
                                                <option value="Sertifikasız">Sertifikasız</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Maden</label>
                                            <select id="editMetal" name="metal" class="form-control">
                                                <option value="">-- Seçin --</option>
                                                <option value="14k Altın">14k Altın</option>
                                                <option value="18k Altın">18k Altın</option>
                                                <option value="Gümüş">Gümüş</option>
                                                <option value="Platin">Platin</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Maden Rengi</label>
                                            <select id="editMetalColor" name="metalColor" class="form-control">
                                                <option value="">-- Seçin --</option>
                                                <option value="Sarı Altın">Sarı Altın</option>
                                                <option value="Beyaz Altın">Beyaz Altın</option>
                                                <option value="Rose Gold">Rose Gold</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Değerli Taş Tipi</label>
                                            <select id="editGemType" name="gemType" class="form-control">
                                                <option value="">-- Seçin --</option>
