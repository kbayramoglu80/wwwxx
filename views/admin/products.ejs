        // EDIT modal — video seçince AJAX ile Cloudinary'ye yükle
        $('#editVideoFile').on('change', function (e) {
            const file = e.target.files[0];
            if (!file) return;
            const container = document.getElementById('editMediaContainer');
            container.querySelectorAll('.draggable-media-item[data-type="video"]').forEach(el => el.remove());
            uploadAndAddMedia(file, container, true, 'video');
            $(this).next('.custom-file-label').addClass('selected').html(file.name + ' yükleniyor...');
            this.value = '';
        });


        // Bootstrap Custom File Input for generic name (with automatic client-side image compression)
        $('.custom-file-input').not('#editGalleryFiles, #editVideoFile, #galleryFiles, #videoFile').on('change', function (e) {
            const inputEl = this;
            const file = e.target.files ? e.target.files[0] : null;

            if (file && file.type.startsWith('image/')) {
                $(inputEl).next('.custom-file-label').html('<i class="fas fa-spinner fa-spin text-warning"></i> Sıkıştırılıyor...');
                compressImage(file, function (compressedFile) {
                    try {
                        const dt = new DataTransfer();
                        dt.items.add(compressedFile);
                        inputEl.files = dt.files;
                        $(inputEl).next('.custom-file-label').addClass("selected").html(compressedFile.name + ' (Sıkıştırıldı)');
                    } catch (err) {
                        console.error('DataTransfer failed:', err);
                        $(inputEl).next('.custom-file-label').addClass("selected").html(file.name);
                    }
                });
            } else {
                let fileName = '';
                if (e.target.files && e.target.files.length > 1) {
                    fileName = e.target.files.length + ' dosya seçildi';
                } else {
                    fileName = $(this).val().split('\\').pop();
                }
                $(this).next('.custom-file-label').addClass("selected").html(fileName);
            }
        });

        // --- Coklu Karat Secenekleri JS Yardimcilari ---
        function addCaratOptionRow(container, carat = '', price = '') {
            const row = document.createElement('div');
            row.className = 'row align-items-center mb-2 carat-option-row';
            row.innerHTML = `
            <div class="col-md-5">
                <div class="input-group input-group-sm">
                    <div class="input-group-prepend">
                        <span class="input-group-text bg-light border-right-0">ct</span>
                    </div>
                    <input type="number" name="caratOptionsCarats" class="form-control border-left-0" placeholder="Karat orn: 1.08" step="0.01" min="0" value="${carat}" required style="border-radius:0 4px 4px 0;">
                </div>
            </div>
            <div class="col-md-5">
                <div class="input-group input-group-sm">
                    <input type="text" name="caratOptionsPrices" class="form-control price-input" placeholder="Fiyat orn: 29.990" value="${price}" required>
                    <div class="input-group-append">
                        <span class="input-group-text bg-light">TL</span>
                    </div>
                </div>
            </div>
            <div class="col-md-2 text-right">
                <button type="button" class="btn btn-sm btn-danger remove-carat-row-btn" style="border-radius:4px; padding: 4px 10px;">
                    <i class="fas fa-trash-alt"></i>
                </button>
            </div>
        `;

            // Silme islemi icin event listener
            row.querySelector('.remove-carat-row-btn').addEventListener('click', function () {
                row.remove();
            });

            // Fiyat girisi icin otomatik binlik ayirici (istege bagli, ama serbest girilebilinsin)
            // Kullanici herhangi bir fiyat girebilir ("istenilen fiyat yazilabilinsin her fiyat")

            container.appendChild(row);
        }

        // Buton dinleyicileri
        document.getElementById('addCaratOptionBtn').addEventListener('click', function () {
            const container = document.getElementById('caratOptionsContainer');
            addCaratOptionRow(container);
        });

        document.getElementById('editAddCaratOptionBtn').addEventListener('click', function () {
            const container = document.getElementById('editCaratOptionsContainer');
            addCaratOptionRow(container);
        });

        function validateProductForm(form) {
            const invalidField = form.querySelector(':invalid');
            if (!invalidField) return true;

            const targetTab = invalidField.closest('.tab-pane');
            if (targetTab) {
                const targetId = targetTab.id;
                const tabLink = form.querySelector(`.nav-tabs a[href="#${targetId}"]`);
                if (tabLink) {
                    const focusInvalid = () => {
                        try {
                            invalidField.focus();
                        } catch (e) {
                            // ignore focus errors on hidden elements
                        }
                    };

                    if (window.jQuery && typeof $(tabLink).tab === 'function') {
                        $(tabLink).one('shown.bs.tab', focusInvalid);
                        try {
                            $(tabLink).tab('show');
                        } catch (e) {
                            tabLink.click();
                            setTimeout(focusInvalid, 150);
                        }
                    } else {
                        tabLink.click();
                        setTimeout(focusInvalid, 150);
                    }

                    return false;
                }
            }

            setTimeout(() => {
                try { invalidField.focus(); } catch (e) { }
            }, 150);
            return false;
        }
    </script>
</body>

</html>