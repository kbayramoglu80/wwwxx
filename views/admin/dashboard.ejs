<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Paneli</title>
    <link rel="stylesheet" href="/assets/css/bootstrap.min.css">
    <link rel="stylesheet" href="/assets/css/fontawesome-all.min.css">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f8f9fa;
        }

        .sidebar {
            min-height: 100vh;
            background: #2c3e50;
            color: white;
            padding-top: 20px;
        }

        .sidebar a {
            color: #bdc3c7;
            display: block;
            padding: 15px;
            text-decoration: none;
            transition: 0.3s;
        }

        .sidebar a:hover,
        .sidebar a.active {
            background: #34495e;
            color: white;
            border-left: 4px solid #d4af37;
        }

        .main-content {
            padding: 30px;
        }

        .card-stat {
            border: none;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            transition: 0.3s;
        }

        .card-stat:hover {
            transform: translateY(-5px);
        }

        .gold-text {
            color: #d4af37;
        }

        .bg-gold {
            background-color: #d4af37;
            color: white;
        }
    </style>
</head>

<body>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-2 sidebar">
                <h4 class="text-center gold-text mb-4">Yönetim Paneli</h4>
                <a href="/admin" class="active"><i class="fas fa-tachometer-alt mr-2"></i> Dashboard</a>
                <a href="/admin/home-settings"><i class="fas fa-home mr-2"></i> Ana Sayfa Yönetimi</a>
                <a href="/admin/products-management"><i class="fas fa-gem mr-2"></i> Ürünler</a>
                <a href="/admin/categories"><i class="fas fa-list mr-2"></i> Kategoriler</a>
                <a href="/admin/orders"><i class="fas fa-shopping-cart mr-2"></i> Siparişler</a>
                <a href="/admin/users"><i class="fas fa-users mr-2"></i> Kullanıcılar</a>
                <a href="/admin/support"><i class="fas fa-comments mr-2"></i> Canlı Destek</a>
                <a href="/admin/banners"><i class="fas fa-image mr-2"></i> Bannerlar</a>
                <a href="/"><i class="fas fa-external-link-alt mr-2"></i> Siteye Git</a>
                <a href="/auth/logout" class="mt-5 text-danger"><i class="fas fa-sign-out-alt mr-2"></i> Çıkış Yap</a>
            </div>

            <!-- Main Content -->
            <div class="col-md-10 main-content">
                <h2 class="mb-4">Dashboard</h2>

                <div class="row mb-4">
                    <div class="col-md-4">
                        <div class="card card-stat bg-white p-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted">Toplam Ürün</h6>
                                    <h3 class="gold-text">
                                        <%= productCount %>
                                    </h3>
                                </div>
                                <i class="fas fa-gem fa-3x text-light"></i>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card card-stat bg-white p-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted">Toplam Sipariş</h6>
                                    <h3 class="gold-text">
                                        <%= orderCount %>
                                    </h3>
                                </div>
                                <i class="fas fa-shopping-cart fa-3x text-light"></i>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card card-stat bg-white p-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted">Toplam Üye</h6>
                                    <h3 class="gold-text">
                                        <%= userCount %>
                                    </h3>
                                </div>
                                <i class="fas fa-users fa-3x text-light"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-none shadow-sm">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">Son Siparişler</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Sipariş No</th>
                                    <th>Müşteri</th>
                                    <th>Tutar</th>
                                    <th>Durum</th>
                                    <th>Tarih</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% recentOrders.forEach(order=> { %>
                                    <tr>
                                        <td>#<%= order._id.toString().substring(0,8) %>
                                        </td>
                                        <td>
                                            <%= order.user ? order.user.name : (order.guestName || 'Misafir' ) %>
                                        </td>
                                        <td>₺<%= order.totalAmount %>
                                        </td>
                                        <td><span class="badge badge-info">
                                                <%= order.orderStatus %>
                                            </span></td>
                                        <td>
                                            <%= order.createdAt.toLocaleDateString('tr-TR') %>
                                        </td>
                                    </tr>
                                    <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/assets/js/vendor/jquery-1.12.4.min.js"></script>
    <script src="/assets/js/bootstrap.min.js"></script>
</body>

</html>