<%- include('partials/head') %>
<%- include('partials/header') %>

<main style="min-height: 75vh; display: flex; flex-direction: column;">
    <div class="slider-area ">
        <div class="single-slider slider-height2 d-flex align-items-center">
            <div class="container">
                <div class="row">
                    <div class="col-xl-12">
                        <div class="hero-cap text-center">
                            <h2>Sepetiniz</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <section class="cart_area" style="background-color: #fcfcfc; flex-grow: 1; padding-bottom: 80px;">
        <div class="container">
            <div class="cart-wrapper" style="background: #ffffff; border-radius: 24px; box-shadow: 0 15px 40px rgba(0,0,0,0.06); padding: 40px; margin-top: -30px; position: relative; z-index: 10;">
                <% if (cart && cart.length > 0) { %>
                <div class="row">
                    <div class="col-lg-8">
                        <div class="cart-items-list pr-lg-4">
                            <h3 class="mb-4" style="font-weight: 800; font-family: 'Inter', sans-serif; color: #1a1a1a;">Sepetim (<%= cartCount %> Ürün)</h3>
                            <% cart.forEach(item => { %>
                                <div class="cart-item d-flex align-items-center mb-4 pb-4" style="border-bottom: 1px solid #f0f0f0;">
                                    <img src="<%= item.imageUrl %>" alt="<%= item.name %>" style="width: 110px; height: 110px; border-radius: 16px; object-fit: cover; box-shadow: 0 5px 15px rgba(0,0,0,0.08);">
                                    <div class="item-details ml-4 flex-grow-1">
                                        <h4 style="font-weight: 700; font-size: 1.25rem; color: #1a1a1a; margin-bottom: 8px;">
                                            <%= item.name %>
                                            <% if (item.selectedCarat) { %>
                                                <span class="badge badge-warning ml-2" style="font-size: 0.8rem; background: #e8e0d0; color: #8a7355; border-radius: 50px; padding: 4px 10px; font-weight: bold;"><%= item.selectedCarat %> ct</span>
                                            <% } %>
                                            <% if (item.selectedSize) { %>
                                                <span class="badge badge-info ml-2" style="font-size: 0.8rem; background: #d0e0e8; color: #55738a; border-radius: 50px; padding: 4px 10px; font-weight: bold;">Ölçü: <%= item.selectedSize %></span>
                                            <% } %>
                                        </h4>
                                        <p class="mb-2" style="color: #888; font-size: 0.95rem;">Birim Fiyat: ₺ <%= item.price.toLocaleString('tr-TR') %></p>
                                        <div class="d-flex align-items-center justify-content-between mt-3">
                                            <div class="item-qty" style="background: #f8f8f8; padding: 6px 20px; border-radius: 50px; font-weight: 700; color: #555;">
                                                Adet: <%= item.quantity %>
                                            </div>
                                            <div class="item-total">
                                                <span style="font-weight: 800; font-size: 1.35rem; color: #ff2020;">₺ <%= (item.price * item.quantity).toLocaleString('tr-TR') %></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="item-actions ml-4 pl-3" style="border-left: 1px solid #f0f0f0;">
                                        <form action="/cart/remove" method="POST" class="m-0">
                                            <input type="hidden" name="productId" value="<%= item.productId %>">
                                            <input type="hidden" name="selectedCarat" value="<%= item.selectedCarat || '' %>">
                                            <input type="hidden" name="selectedSize" value="<%= item.selectedSize || '' %>">
                                            <button type="submit" class="btn" style="background: #fff; color: #dc3545; border: 2px solid #ffeaec; border-radius: 50%; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; padding: 0; transition: all 0.3s;" onmouseover="this.style.background='#dc3545'; this.style.color='#fff';" onmouseout="this.style.background='#fff'; this.style.color='#dc3545';" title="Sepetten Çıkar">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                    <div class="col-lg-4 mt-5 mt-lg-0">
                        <div class="cart-summary p-4" style="background: #fafafa; border: 1px solid #f0f0f0; border-radius: 20px;">
                            <h3 style="font-weight: 800; margin-bottom: 30px; font-family: 'Inter', sans-serif; color: #1a1a1a;">Sipariş Özeti</h3>
                            <div class="d-flex justify-content-between mb-3" style="color: #555; font-size: 1.05rem;">
                                <span>Ara Toplam</span>
                                <span style="font-weight: 600; color: #1a1a1a;">₺ <%= cartTotal.toFixed(2) %></span>
                            </div>
                            <div class="d-flex justify-content-between mb-3" style="color: #555; font-size: 1.05rem;">
                                <span>Kargo Tutarı</span>
                                <span style="font-weight: 700; color: #28a745;">Ücretsiz</span>
                            </div>
                            <hr style="border-color: #eee; margin: 25px 0;">
                            <div class="d-flex justify-content-between mb-4 mt-3">
                                <span style="font-size: 1.15rem; font-weight: 700; color: #1a1a1a;">Genel Toplam</span>
                                <span style="font-size: 1.8rem; font-weight: 800; color: #ff2020; line-height: 1;">₺ <%= cartTotal.toFixed(2) %></span>
                            </div>
                            <a href="/checkout" class="btn_3 w-100 text-center" style="border-radius: 50px; padding: 18px 0; font-weight: 800; font-size: 1.1rem; letter-spacing: 0.5px; text-transform: uppercase; background: #1a1a1a; color: #fff; border: none; box-shadow: 0 8px 20px rgba(0,0,0,0.15);">Güvenli Ödemeye Geç</a>
                            <a href="/shop" class="d-block text-center mt-4" style="color: #666; font-weight: 600; font-size: 1.05rem; text-decoration: underline;">Alışverişe Devam Et</a>
                        </div>
                    </div>
                </div>
                <% } else { %>
                <div class="text-center py-5">
                    <div style="font-size: 100px; color: #f0f0f0; margin-bottom: 25px;">
                        <i class="fas fa-shopping-bag"></i>
                    </div>
                    <h3 style="font-weight: 800; font-family: 'Inter', sans-serif; color: #1a1a1a; font-size: 2.2rem;">Sepetiniz şu an boş</h3>
                    <p class="text-muted mb-5" style="font-size: 1.1rem;">Sepetinizi doldurmak için harika mücevherler sizi bekliyor.</p>
                    <a class="btn_3" href="/shop" style="border-radius: 50px; padding: 16px 45px; font-weight: 800; font-size: 1.1rem; background: #1a1a1a; color: #fff; border: none; box-shadow: 0 8px 20px rgba(0,0,0,0.15);">Hemen Alışverişe Başla</a>
                </div>
                <% } %>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>
