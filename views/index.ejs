<%- include('partials/head') %>
    <%- include('partials/header') %>

        <main>
            <style>
                /* Hero ile altındaki bölüm arasındaki boşluğu azaltma */
                .new-arrival.hero-adjacent-section {
                    padding-top: 15px !important;
                }

                /* Ana sayfa ürün ızgarası */
                .premium-grid {
                    display: grid;
                    grid-template-columns: repeat(4, minmax(240px, 1fr));
                    gap: 32px 24px;
                    align-items: stretch;
                }

                .premium-card {
                    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
                }

                .premium-card:hover {
                    transform: translateY(-8px);
                }

                @media (max-width: 1200px) {
                    .premium-grid {
                        grid-template-columns: repeat(3, minmax(220px, 1fr));
                    }
                }

                @media (max-width: 991px) {
                    .premium-grid {
                        grid-template-columns: repeat(2, minmax(220px, 1fr));
                    }
                }

                @media (max-width: 575px) {
                    .premium-grid {
                        grid-template-columns: 1fr;
                        gap: 20px 16px;
                    }
                }

                .slider-area {
                    margin-top: 280px;
                    padding-top: 0;
                    min-height: auto;
                }

                @media (min-width: 992px) {
                    .slider-area {
                        margin-top: 280px;
                        min-height: auto;
                    }
                }

                .home-banner {
                    min-height: 0;
                    align-items: center;
                }

                .home-banner-img {
                    width: auto;
                    max-width: 100%;
                    height: auto;
                    max-height: 520px;
                    object-fit: contain;
                    display: block;
                    margin: 0 auto;
                    border: none;
                    box-shadow: none;
                    padding: 0;
                    animation: bannerImageFade 1.2s ease both;
                }

                .home-banner-img.full-bleed {
                    width: auto;
                    max-width: 100%;
                    margin: 0 auto;
                }

                @media (min-width: 1200px) {
                    .home-banner-img {
                        max-height: 520px;
                    }
                }

                @media (max-width: 991px) {
                    .home-banner-img {
                        width: 100%;
                        max-height: none;
                        object-fit: cover;
                    }
                }

                @media (max-width: 767px) {
                    .home-banner-img {
                        width: 100%;
                        object-fit: cover;
                    }
                }

                @media (max-width: 767px) {
                    .home-banner-img {
                        width: 100%;
                    }
                }

                @media (max-width: 575px) {
                    .home-banner-img {
                        width: 100%;
                    }
                }

                @keyframes bannerImageFade {
                    from {
                        opacity: 0;
                        filter: blur(6px);
                    }
                    to {
                        opacity: 1;
                        filter: blur(0);
                    }
                }

                .hero__caption h1 {
                    font-size: 3.2rem;
                    font-weight: 800;
                    letter-spacing: -0.03em;
                    text-shadow: 0 8px 30px rgba(0,0,0,0.24);
                }

                .hero__caption .hero-cta {
                    background: rgba(255,255,255,0.96) !important;
                    color: #140c40 !important;
                    border-radius: 999px;
                    padding: 13px 28px;
                    font-weight: 700;
                    box-shadow: 0 12px 30px rgba(0,0,0,0.18);
                    transition: transform 0.2s ease, box-shadow 0.2s ease;
                }

                .hero__caption .hero-cta:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 16px 36px rgba(0,0,0,0.24);
                }

                .section-tittle h2 {
                    font-size: 2rem;
                    font-weight: 800;
                    color: #140c40;
                    letter-spacing: -0.02em;
                    margin-bottom: 10px;
                }

                .section-tittle p {
                    color: #6b7280;
                    font-size: 1rem;
                    line-height: 1.7;
                }

                @media (max-width: 991px) {
                    .slider-area {
                        margin-top: 24px;
                    }
                }

                @media (max-width: 767px) {
                    .slider-area .hero__caption {
                        padding: 0 12px !important;
                    }

                    .slider-area .hero__caption h1 {
                        font-size: 28px;
                        /* Mobilde daha okunaklı ve dengeli bir yazı boyutu */
                        line-height: 1.2;
                        margin-bottom: 18px;
                    }
                }

                @media (max-width: 575px) {
                    .slider-area .hero__caption h1 {
                        font-size: 24px;
                    }
                }
                /* Desktop banner displayed as image to avoid cropping */
                .home-banner {
                    display: flex;
                    justify-content: center;
                    align-items: center;
                    padding: 0;
                    background-color: transparent;
                    margin: 0;
                    border: none;
                    box-shadow: none;
                    animation: bannerReveal 1s ease both;
                    overflow: hidden;
                    border-radius: 24px;
                    position: relative;
                }

                .banner-cta {
                    position: absolute;
                    bottom: 30px;
                    left: 50%;
                    transform: translateX(-50%);
                    z-index: 20;
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    text-decoration: none;
                    background: #192b3b;
                    padding: 8px 12px;
                    border-radius: 10px;
                    border: 1px solid #e7e7e7;
                    color: #ffffff;
                    font-size: 1rem;
                    font-weight: 700;
                    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
                    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
                }

                .banner-cta:hover {
                    transform: translateX(-50%) translateY(-2px);
                    background: #ffffff;
                    box-shadow: 0 22px 46px rgba(0, 0, 0, 0.22);
                }

                .banner-cta i {
                    margin-left: 10px;
                }

                @keyframes bannerReveal {
                    from {
                        opacity: 0;
                        transform: translateY(16px) scale(0.98);
                    }
                    to {
                        opacity: 1;
                        transform: translateY(0) scale(1);
                    }
                }

                @keyframes bannerImageFade {
                    from {
                        opacity: 0;
                        filter: blur(6px);
                    }
                    to {
                        opacity: 1;
                        filter: blur(0);
                    }
                }

                @media (min-width: 992px) {
                    .home-banner-img.full-bleed {
                        width: 100vw;
                        max-width: none;
                        margin-left: calc(50% - 50vw);
                        margin-right: calc(50% - 50vw);
                    }
                }

                @media (max-width: 1199px) {
                    .home-banner-img { max-height: 620px; }
                }

                @media (max-width: 991px) {
                    .home-banner-img { max-height: 620px; }
                }

                @media (max-width: 767px) {
                    .home-banner-img {
                        max-height: 520px;
                        width: 100%;
                    }
                }

                @media (max-width: 575px) {
                    .home-banner-img { max-height: 732px; }
                }
            </style>

            <!--? Hero Area Start-->
            <div class="container-fluid p-0">
                <div class="slider-area">
                    <div class="single-slider hero-overly d-flex align-items-center home-banner"
                        style="cursor: pointer; margin-top: 0; padding-top: 0;" onclick="window.location.href='/shop'">
                        <picture>
                            <source media="(max-width: 767px)" srcset="/assets/img/hero/banner-mobil.png">
                            <img src="/assets/img/hero/masaustu_banner.png" alt="Ana Banner" class="home-banner-img full-bleed">
                        </picture>
                        <a href="/shop" class="banner-cta">Ürünleri İncele <i class="fas fa-arrow-right"></i></a>
                    </div>
                </div>
            </div>

            <!--? Benefits Area Start -->
            <div class="categories-area" style="padding: 36px 0 24px; background: linear-gradient(180deg, #fcfaf6 0%, #f8f3e8 100%);">
                <div class="container">
                    <div class="row justify-content-center mb-4">
                        <div class="col-xl-7 col-lg-8 col-md-10 text-center">
                            <div class="section-tittle mb-3">
                                <h2>Neden Giz Pırlanta?</h2>
                                <p>İhtiyaçlarınıza uygun, özenle seçilmiş ürünleri güvenli bir deneyimle sunuyoruz.</p>
                            </div>
                        </div>
                    </div>
                    <div class="row g-4">
                        <div class="col-lg-3 col-md-6">
                            <div class="service-modern-card">
                                <div class="service-modern-icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="4" width="18" height="14" rx="2"></rect><path d="M7 8h10"></path><path d="M7 12h6"></path></svg>
                                </div>
                                <h5>Sigortalı Teslimat</h5>
                                <p>Güvenli paketleme ve hızlı kargo ile kapınıza kadar güvenle ulaşıyor.</p>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="service-modern-card">
                                <div class="service-modern-icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="M3 10h18"></path></svg>
                                </div>
                                <h5>Güvenli Ödeme</h5>
                                <p>Modern güvenlik altyapısı ile anında ve sorunsuz ödeme deneyimi sunar.</p>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="service-modern-card">
                                <div class="service-modern-icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path></svg>
                                </div>
                                <h5>Kolay İade</h5>
                                <p>İstediğiniz an kolayca değişim ya da iade imkanı sağlar.</p>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="service-modern-card">
                                <div class="service-modern-icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.4 2 2 0 0 1 3.57 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.76a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.03z"></path></svg>
                                </div>
                                <h5>7/24 Destek</h5>
                                <p>Her zaman yardım almak için uzman ekibimizle yanınızdayız.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!--? Benefits Area End -->

            <!--? New Arrival Start -->
            <div class="new-arrival">
                <div class="container">
                    <!-- Section title & Sorting Dropdown -->
                    <div class="row justify-content-center mb-40">
                        <div class="col-xl-7 col-lg-8 col-md-10 text-center">
                            <div class="section-tittle mb-20">
                                <h2>
                                    <%= typeof setting !=='undefined' ? (setting.newArrivalTitle || 'Öne Çıkan Koleksiyonlar' )
                                        : 'Öne Çıkan Koleksiyonlar' %>
                                </h2>
                                <p>En yeni ve en çok beğenilen parçaları keşfedin.</p>
                            </div>
                            <!-- Premium Sorting Dropdown -->
                            <div class="sorting-wrapper">
                                <label for="homeProductSort">Sıralama:</label>
                                <select id="homeProductSort">
                                    <option value="newest" selected>En Yeniler (Varsayılan)</option>
                                    <option value="price-asc">Fiyat: Düşükten Yükseğe</option>
                                    <option value="price-desc">Fiyat: Yüksekten Düşüğe</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="premium-grid" id="homeProductGrid">
                        <% if (typeof products !=='undefined' && products.length> 0) { %>
                            <% products.forEach((product, index)=> {
                                const isHidden = index >= 16;
                                %>
                                            <div class="premium-card <%= isHidden ? 'premium-card-hidden' : '' %>"
                                    data-price="<%= product.price %>"
                                    data-date="<%= product.createdAt ? product.createdAt.getTime() : 0 %>"
                                    style="<%= isHidden ? 'display: none !important;' : '' %>">
                                    <div class="premium-card-img-wrapper">
                                        <a href="/product/<%= product._id %>">
                                            <img src="<%= product.imageUrl %>" alt="<%= product.name %>"
                                                class="primary-img">
                                            <img src="<%= product.imageUrl %>" alt="<%= product.name %>"
                                                class="secondary-img" style="filter: brightness(0.95);">
                                        </a>
                                        <button class="fav-btn" data-id="<%= product._id %>">
                                            <i
                                                class="<%= (typeof userFavorites !== 'undefined' && userFavorites.includes(product._id.toString())) ? 'fas fa-heart text-danger' : 'far fa-heart' %>"></i>
                                        </button>
                                    </div>
                                    <div class="premium-card-info">
                                        <div class="premium-card-title"><a href="/product/<%= product._id %>">
                                                <%= product.name %>
                                            </a></div>
                                        <div class="premium-card-desc">
                                            <%= product.description ? product.description.substring(0,30) + '...'
                                                : 'Pırlanta Şıklığı' %>
                                        </div>
                                        <div class="premium-card-price-wrap">
                                            <span class="premium-card-price">₺ <%= product.price.toLocaleString('tr-TR')
                                                    %></span>
                                            <% if (product.price> 1000) { %>
                                                <span class="premium-card-old-price">₺ <%= Math.round(product.price *
                                                        1.2).toLocaleString('tr-TR') %></span>
                                                <% } %>
                                        </div>
                                        <div class="card-actions">
                                            <a href="/product/<%= product._id %>" class="btn-premium-secondary"
                                                style="padding: 10px; font-size: 10px;">İncele</a>
                                            <button
                                                onclick="openHomeAddToCartModal('<%= product._id %>', '<%= product.name %>', '<%= product.price %>', '<%= product.imageUrl %>')"
                                                class="btn-premium-primary"
                                                style="padding: 10px; font-size: 10px;">Sepete Ekle</button>
                                        </div>
                                    </div>
                                </div>
                                <% }); %>
                                    <% } else { %>
                                        <div style="grid-column: 1 / -1; text-align: center; padding: 50px 0;">
                                            <p style="font-size: 16px; color: #888;">Henüz ürün eklenmemiş.</p>
                                        </div>
                                        <% } %>
                    </div>
                    <!-- Expandable Show More Button -->
                    <div class="row justify-content-center" style="margin-top: 40px; margin-bottom: 20px;">
                        <div class="room-btn" id="showMoreContainer"
                            style="<%= (typeof products !== 'undefined' && products.length <= 16) ? 'display: none;' : 'display: flex;' %>">
                            <button id="btnShowMore" class="border-btn"
                                style="background: transparent; cursor: pointer; border: 1px solid #c49b45; padding: 15px 35px; font-weight: bold; text-transform: uppercase; font-size: 12px; letter-spacing: 2px; transition: all 0.3s ease; border-radius: 4px;">Daha
                                Fazla Göster</button>
                        </div>
                    </div>
                </div>
            </div>
            <!--? New Arrival End -->

            <!--? Dinamik Özel Reyonlar Başlangıcı -->
            <% if (typeof sections !=='undefined' && sections.length> 0) { %>
                <% sections.forEach(sec=> { %>
                    <% if (sec.products && sec.products.length> 0) { %>
                        <div class="new-arrival dynamic-section pt-50 pb-50"
                            style="border-top: 1px solid rgba(0,0,0,0.03);">
                            <div class="container">
                                <div class="row justify-content-center mb-40">
                                    <div class="col-xl-7 col-lg-8 col-md-10 text-center">
                                        <div class="section-tittle mb-20">
                                            <h2>
                                                <%= sec.title %>
                                            </h2>
                                            <p>Seçkin ürünlerden oluşan bu bölümde stilinizi tamamlayın.</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="premium-grid">
                                    <% sec.products.forEach(product=> { %>
                                        <div class="premium-card">
                                            <div class="premium-card-img-wrapper">
                                                <a href="/product/<%= product._id %>">
                                                    <img src="<%= product.imageUrl %>" alt="<%= product.name %>"
                                                        class="primary-img">
                                                    <img src="<%= product.imageUrl %>" alt="<%= product.name %>"
                                                        class="secondary-img" style="filter: brightness(0.95);">
                                                </a>
                                                <button class="fav-btn" data-id="<%= product._id %>">
                                                    <i
                                                        class="<%= (typeof userFavorites !== 'undefined' && userFavorites.includes(product._id.toString())) ? 'fas fa-heart text-danger' : 'far fa-heart' %>"></i>
                                                </button>
                                            </div>
                                            <div class="premium-card-info">
                                                <div class="premium-card-title"><a href="/product/<%= product._id %>">
                                                        <%= product.name %>
                                                    </a></div>
                                                <div class="premium-card-desc">
                                                    <%= product.description ? product.description.substring(0,30)
                                                        + '...' : 'Pırlanta Şıklığı' %>
                                                </div>
                                                <div class="premium-card-price-wrap">
                                                    <span class="premium-card-price">₺ <%=
                                                            product.price.toLocaleString('tr-TR') %></span>
                                                    <% if (product.price> 1000) { %>
                                                        <span class="premium-card-old-price">₺ <%=
                                                                Math.round(product.price * 1.2).toLocaleString('tr-TR')
                                                                %></span>
                                                        <% } %>
                                                </div>
                                                <div class="card-actions">
                                                    <a href="/product/<%= product._id %>" class="btn-premium-secondary"
                                                        style="padding: 10px; font-size: 10px;">İncele</a>
                                                    <button
                                                        onclick="openHomeAddToCartModal('<%= product._id %>', '<%= product.name %>', '<%= product.price %>', '<%= product.imageUrl %>')"
                                                        class="btn-premium-primary"
                                                        style="padding: 10px; font-size: 10px;">Sepete Ekle</button>
                                                </div>
                                            </div>
                                        </div>
                                        <% }); %>
                                </div>
                            </div>
                        </div>
                        <% } %>
                            <% }); %>
                                <% } %>
                                    <!--? Dinamik Özel Reyonlar Bitişi -->

                                    <style>
                                        /* Custom CSS styling for premium sort dropdown and hidden items */
                                        .premium-card-hidden {
                                            display: none !important;
                                        }

                        .service-modern-card {
                            background: #ffffff;
                            border: 1px solid #eee3d2;
                            border-radius: 22px;
                            padding: 24px 20px;
                            height: 100%;
                            box-shadow: 0 10px 30px rgba(20, 12, 64, 0.04);
                            transition: transform 0.2s ease, box-shadow 0.2s ease;
                        }

                        .service-modern-card:hover {
                            transform: translateY(-3px);
                            box-shadow: 0 16px 40px rgba(20, 12, 64, 0.08);
                        }

                        .service-modern-icon {
                            width: 46px;
                            height: 46px;
                            display: inline-flex;
                            align-items: center;
                            justify-content: center;
                            border-radius: 14px;
                            background: linear-gradient(135deg, #140c40 0%, #2e2b5f 100%);
                            color: #fff;
                            margin-bottom: 14px;
                        }

                        .service-modern-icon svg {
                            width: 22px;
                            height: 22px;
                        }

                        .service-modern-card h5 {
                            font-size: 16px;
                            font-weight: 700;
                            color: #140c40;
                            margin-bottom: 8px;
                        }

                        .service-modern-card p {
                            font-size: 13px;
                            color: #6b7280;
                            line-height: 1.65;
                            margin-bottom: 0;
                        }
                                            transform: translateY(-2px);
                                        }
                                    </style>


                                    <script>
                                        document.addEventListener('DOMContentLoaded', function () {
                                            const grid = document.getElementById('homeProductGrid');
                                            const sortSelect = document.getElementById('homeProductSort');
                                            const btnShowMore = document.getElementById('btnShowMore');
                                            const showMoreContainer = document.getElementById('showMoreContainer');

                                            let visibleLimit = 16;

                                            function updateVisibility() {
                                                if (!grid) return;
                                                const cards = Array.from(grid.querySelectorAll('.premium-card'));
                                                cards.forEach((card, index) => {
                                                    if (index < visibleLimit) {
                                                        card.style.setProperty('display', 'block', 'important');
                                                        card.classList.remove('premium-card-hidden');
                                                    } else {
                                                        card.style.setProperty('display', 'none', 'important');
                                                        card.classList.add('premium-card-hidden');
                                                    }
                                                });

                                                if (showMoreContainer) {
                                                    if (visibleLimit >= cards.length) {
                                                        showMoreContainer.style.setProperty('display', 'none', 'important');
                                                    } else {
                                                        showMoreContainer.style.setProperty('display', 'flex', 'important');
                                                    }
                                                }
                                            }

                                            function sortProducts(sortBy) {
                                                if (!grid) return;
                                                const cards = Array.from(grid.querySelectorAll('.premium-card'));

                                                cards.sort((a, b) => {
                                                    if (sortBy === 'price-asc') {
                                                        return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
                                                    } else if (sortBy === 'price-desc') {
                                                        return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
                                                    } else {
                                                        // newest
                                                        return parseFloat(b.dataset.date) - parseFloat(a.dataset.date);
                                                    }
                                                });

                                                cards.forEach(card => grid.appendChild(card));

                                                visibleLimit = 16;
                                                updateVisibility();
                                            }

                                            if (sortSelect) {
                                                $(sortSelect).on('change', function () {
                                                    sortProducts(this.value);
                                                });
                                            }

                                            if (btnShowMore) {
                                                btnShowMore.addEventListener('click', function () {
                                                    visibleLimit += 16;
                                                    updateVisibility();
                                                });
                                            }

                                            updateVisibility();
                                        });

                                        // Ana sayfa yüzük ölçü tablosu
                                        const ringSizeChartHome = [
                                            { size: 7, diameter: 14.96 },
                                            { size: 8, diameter: 15.28 },
                                            { size: 9, diameter: 15.61 },
                                            { size: 10, diameter: 15.92 },
                                            { size: 11, diameter: 16.24 },
                                            { size: 12, diameter: 16.56 },
                                            { size: 13, diameter: 16.88 },
                                            { size: 14, diameter: 17.20 },
                                            { size: 15, diameter: 17.52 },
                                            { size: 16, diameter: 17.83 },
                                            { size: 17, diameter: 18.15 },
                                            { size: 18, diameter: 18.47 },
                                            { size: 19, diameter: 18.79 },
                                            { size: 20, diameter: 19.11 },
                                            { size: 21, diameter: 19.43 },
                                            { size: 22, diameter: 19.75 },
                                            { size: 23, diameter: 20.06 },
                                            { size: 24, diameter: 20.38 },
                                            { size: 25, diameter: 20.70 },
                                            { size: 26, diameter: 21.02 },
                                            { size: 27, diameter: 21.34 },
                                            { size: 28, diameter: 21.66 },
                                            { size: 29, diameter: 21.97 },
                                            { size: 30, diameter: 22.29 }
                                        ];

                                        let currentProduct = null;
                                        let mcurrentStepHome = 1;
                                        let mpxPerMmHome = 7.6481;
                                        let mcalibrationCirclePixelsHome = 200;

                                        // Ana sayfa sepete ekleme modalı
                                        function openHomeAddToCartModal(productId, productName, productPrice, productImage) {
                                            currentProduct = {
                                                _id: productId,
                                                name: productName,
                                                price: productPrice,
                                                imageUrl: productImage
                                            };

                                            const modal = document.getElementById('addToCartModal');
                                            const content = document.getElementById('modal-product-content');

                                            // Modal içeriğini doldur
                                            content.innerHTML = `
                                                <img src="${productImage}" alt="${productName}" style="width: 120px; height: 120px; object-fit: cover; border-radius: 12px; margin-bottom: 15px;">
                                                <h3 style="font-size: 18px; font-weight: 700; color: #140C40; margin-bottom: 8px;">${productName}</h3>
                                                <p style="font-size: 20px; font-weight: 700; color: #ff2020; margin-bottom: 20px;">₺${parseFloat(productPrice).toLocaleString('tr-TR')}</p>
                                                
                                                <div class="variation-group" style="text-align: left; margin-bottom: 15px;">
                                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                                                        <span style="font-weight: 600; color: #333;">Yüzük Ölçüsü</span>
                                                        <a href="javascript:void(0)" onclick="openRingSizeModalHome()" style="font-size: 12px; color: #c5a059; font-weight: 600; text-decoration: underline;"><i class="fas fa-question-circle"></i> Ölçümü Nasıl Bulurum?</a>
                                                    </div>
                                                    <select id="selected-size-home" class="premium-select" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px;">
                                                        <option value="">Seçiniz</option>
                                                        ${ringSizeChartHome.map(s => `<option value="${s.size}">${s.size}</option>`).join('')}
                                                    </select>
                                                </div>
                                                
                                                <div style="display: flex; gap: 10px; margin-top: 20px;">
                                                    <button onclick="closeAddToCartModal()" class="btn-premium-secondary" style="flex: 1; padding: 12px 20px; font-size: 14px;">İptal</button>
                                                    <button onclick="addToCartFromHome()" class="btn-premium-primary" style="flex: 1; padding: 12px 20px; font-size: 14px;">Sepete Ekle</button>
                                                </div>
                                            `;

                                            modal.style.display = 'flex';
                                            document.body.style.overflow = 'hidden';
                                        }

                                        function closeAddToCartModal() {
                                            const modal = document.getElementById('addToCartModal');
                                            modal.style.display = 'none';
                                            document.body.style.overflow = '';
                                        }

                                        // Ana sayfadan sepete ekleme
                                        function addToCartFromHome() {
                                            if (!currentProduct) return;

                                            const sizeSelect = document.getElementById('selected-size-home');
                                            const selectedSize = sizeSelect.value;

                                            if (!selectedSize) {
                                                alert('Lütfen bir yüzük ölçüsü seçin!');
                                                return;
                                            }

                                            // Form oluşturalım ve POST edelim
                                            const form = document.createElement('form');
                                            form.method = 'POST';
                                            form.action = '/cart/add';

                                            const productIdInput = document.createElement('input');
                                            productIdInput.type = 'hidden';
                                            productIdInput.name = 'productId';
                                            productIdInput.value = currentProduct._id;

                                            const qtyInput = document.createElement('input');
                                            qtyInput.type = 'hidden';
                                            qtyInput.name = 'quantity';
                                            qtyInput.value = '1';

                                            const sizeInput = document.createElement('input');
                                            sizeInput.type = 'hidden';
                                            sizeInput.name = 'selectedSize';
                                            sizeInput.value = selectedSize;

                                            form.appendChild(productIdInput);
                                            form.appendChild(qtyInput);
                                            form.appendChild(sizeInput);

                                            document.body.appendChild(form);
                                            form.submit();
                                        }

                                        // Ana sayfa yüzük ölçü bulma modalı fonksiyonları
                                        function openRingSizeModalHome() {
                                            const modal = document.getElementById('ringSizeModalHome');
                                            modal.style.display = 'flex';
                                            document.body.style.overflow = 'hidden';

                                            goToModalStepHome(1);

                                            // Select'i doldur
                                            const selectEl = document.getElementById('msize-comparator-select-h');
                                            if (selectEl && selectEl.children.length === 0) {
                                                ringSizeChartHome.forEach(item => {
                                                    const option = document.createElement('option');
                                                    option.value = item.size;
                                                    option.text = `Ölçü ${item.size} (${item.diameter.toFixed(2)} mm)`;
                                                    if (item.size === 15) option.selected = true;
                                                    selectEl.appendChild(option);
                                                });
                                            }
                                        }

                                        function closeRingSizeModalHome() {
                                            const modal = document.getElementById('ringSizeModalHome');
                                            modal.style.display = 'none';
                                            document.body.style.overflow = '';
                                        }

                                        function goToModalStepHome(step) {
                                            document.querySelectorAll('#mstep-content-h1, #mstep-content-h2, #mstep-content-h3').forEach(el => el.style.display = 'none');
                                            document.getElementById(`mstep-content-h${step}`).style.display = 'block';

                                            document.querySelectorAll('#mstep-dot-h1, #mstep-dot-h2, #mstep-dot-h3').forEach((el, index) => {
                                                const dotNum = index + 1;
                                                const numEl = el.querySelector('.modal-step-num');

                                                if (dotNum < step) {
                                                    el.style.color = '#c5a059';
                                                    if (numEl) {
                                                        numEl.style.background = '#28a745';
                                                        numEl.style.color = '#fff';
                                                        numEl.innerHTML = '<i class="fas fa-check"></i>';
                                                    }
                                                } else if (dotNum === step) {
                                                    el.style.color = '#c5a059';
                                                    if (numEl) {
                                                        numEl.style.background = '#c5a059';
                                                        numEl.style.color = '#fff';
                                                        numEl.innerHTML = dotNum;
                                                    }
                                                } else {
                                                    el.style.color = '#aaa';
                                                    if (numEl) {
                                                        numEl.style.background = '#eee';
                                                        numEl.style.color = '#888';
                                                        numEl.innerHTML = dotNum;
                                                    }
                                                }
                                            });

                                            mcurrentStepHome = step;

                                            if (step === 3) {
                                                calculateModalRingSizeHome(document.getElementById('mring-measure-slider-h').value);
                                                updateModalComparatorSizeHome(document.getElementById('msize-comparator-select-h').value);
                                            }
                                        }

                                        function resizeModalCalibrationCircleHome(px) {
                                            mcalibrationCirclePixelsHome = parseInt(px);
                                            const circle = document.getElementById('mcalibration-circle-h');
                                            circle.style.width = px + 'px';
                                            circle.style.height = px + 'px';
                                            document.getElementById('mcal-pixels-label-h').innerText = `Genişlik: ${px}px`;
                                        }

                                        function tuneModalCalibrationHome(change) {
                                            const slider = document.getElementById('mcalibration-slider-h');
                                            let newValue = parseInt(slider.value) + change;
                                            if (newValue >= 150 && newValue <= 300) {
                                                slider.value = newValue;
                                                resizeModalCalibrationCircleHome(newValue);
                                            }
                                        }

                                        function saveModalCalibrationAndContinueHome() {
                                            mpxPerMmHome = mcalibrationCirclePixelsHome / 26.15;
                                            goToModalStepHome(3);
                                        }

                                        function switchModalMeasureModeHome(mode) {
                                            document.getElementById('mmode-content-ring-h').style.display = mode === 'ring' ? 'block' : 'none';
                                            document.getElementById('mmode-content-circles-h').style.display = mode === 'circles' ? 'block' : 'none';
                                            document.getElementById('mtab-btn-ring-h').className = 'measure-tab-btn ' + (mode === 'ring' ? 'active' : '');
                                            document.getElementById('mtab-btn-circles-h').className = 'measure-tab-btn ' + (mode === 'circles' ? 'active' : '');
                                            if (mode === 'ring') {
                                                document.getElementById('mtab-btn-ring-h').style.background = '#c5a059';
                                                document.getElementById('mtab-btn-ring-h').style.color = '#fff';
                                                document.getElementById('mtab-btn-ring-h').style.borderColor = '#c5a059';
                                                document.getElementById('mtab-btn-circles-h').style.background = '#fff';
                                                document.getElementById('mtab-btn-circles-h').style.color = '#555';
                                                document.getElementById('mtab-btn-circles-h').style.borderColor = '#ccc';
                                            } else {
                                                document.getElementById('mtab-btn-circles-h').style.background = '#c5a059';
                                                document.getElementById('mtab-btn-circles-h').style.color = '#fff';
                                                document.getElementById('mtab-btn-circles-h').style.borderColor = '#c5a059';
                                                document.getElementById('mtab-btn-ring-h').style.background = '#fff';
                                                document.getElementById('mtab-btn-ring-h').style.color = '#555';
                                                document.getElementById('mtab-btn-ring-h').style.borderColor = '#ccc';
                                            }
                                        }

                                        function resizeModalRingMeasureCircleHome(px) {
                                            const circle = document.getElementById('mring-measure-circle-h');
                                            circle.style.width = px + 'px';
                                            circle.style.height = px + 'px';
                                            calculateModalRingSizeHome(px);
                                        }

                                        function tuneModalRingMeasureHome(change) {
                                            const slider = document.getElementById('mring-measure-slider-h');
                                            let newValue = parseInt(slider.value) + change;
                                            if (newValue >= 100 && newValue <= 220) {
                                                slider.value = newValue;
                                                resizeModalRingMeasureCircleHome(newValue);
                                            }
                                        }

                                        function calculateModalRingSizeHome(px) {
                                            const diameterMm = px / mpxPerMmHome;
                                            let closestSize = 15;
                                            let closestDiff = Infinity;

                                            ringSizeChartHome.forEach(item => {
                                                const diff = Math.abs(item.diameter - diameterMm);
                                                if (diff < closestDiff) {
                                                    closestDiff = diff;
                                                    closestSize = item.size;
                                                }
                                            });

                                            document.getElementById('mring-size-result-label-h').innerText = closestSize;
                                            document.getElementById('mring-diameter-result-label-h').innerText = diameterMm.toFixed(2) + ' mm';
                                        }

                                        function updateModalComparatorSizeHome(size) {
                                            const sizeData = ringSizeChartHome.find(s => s.size === parseInt(size));
                                            if (sizeData) {
                                                const pxSize = Math.round(sizeData.diameter * mpxPerMmHome);
                                                const circle = document.getElementById('mring-compare-circle-h');
                                                circle.style.width = pxSize + 'px';
                                                circle.style.height = pxSize + 'px';
                                                document.getElementById('mring-compare-label-h').innerText = size;
                                                document.getElementById('mring-compare-diameter-label-h').innerText = sizeData.diameter.toFixed(2) + ' mm';
                                            }
                                        }

                                        function applyRingSizeToHomeModal() {
                                            const foundSize = document.getElementById('mring-size-result-label-h').innerText;
                                            const sizeSelect = document.getElementById('selected-size-home');
                                            if (sizeSelect) {
                                                sizeSelect.value = foundSize;
                                            }
                                            closeRingSizeModalHome();
                                        }

                                        // Modal dışına tıklandığında kapat
                                        window.addEventListener('click', function (event) {
                                            const addModal = document.getElementById('addToCartModal');
                                            const sizeModal = document.getElementById('ringSizeModalHome');
                                            if (event.target === addModal) {
                                                closeAddToCartModal();
                                            }
                                            if (event.target === sizeModal) {
                                                closeRingSizeModalHome();
                                            }
                                        });
                                    </script>

        </main>


